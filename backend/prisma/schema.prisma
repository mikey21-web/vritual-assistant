// === REFRESH TOKENS ===

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// === PASSWORD RESET TOKEN ===

model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

// === USER MODEL ===

model User {
  id                        String                @id @default(uuid())
  tenantId                  String                @map("tenant_id")
  tenant                    Tenant                @relation(fields: [tenantId], references: [id])
  name                      String
  email                     String                @unique
  phone                     String?
  password                  String
  role                      UserRole              @default(SALES_AGENT)
  active                    Boolean               @default(true)
  emailVerifiedAt           DateTime?
  mfaEnabled                Boolean               @default(false)
  mfaSecret                 String?
  lockoutUntil              DateTime?
  failedLoginAttempts       Int                   @default(0)
  managerId                 String?
  manager                   User?                 @relation("UserManager", fields: [managerId], references: [id])
  directReports             User[]                @relation("UserManager")
  territoryAssignments      TerritoryAssignment[]
  agentAvailability         AgentAvailability?
  callQualityReviewsGiven   CallQualityReview[]
  visitAttendancesCheckedIn VisitAttendance[]
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt

  assignedLeads                   Lead[]
  createdCampaigns                Campaign[]                  @relation("CampaignCreator")
  assignedCampaigns               Campaign[]                  @relation("CampaignAssignee")
  createdTemplates                MessageTemplate[]
  createdMedia                    MediaFile[]                 @relation("MediaUploader")
  auditLogs                       AuditLog[]
  tasks                           Task[]
  savedFilters                    SavedFilter[]
  internalNotes                   InternalNote[]
  notificationPrefs               NotificationPreference[]
  importExportLogs                ImportExportLog[]
  ownershipFrom                   LeadOwnershipHistory[]      @relation("OwnershipFromUser")
  ownershipTo                     LeadOwnershipHistory[]      @relation("OwnershipToUser")
  ownershipChanged                LeadOwnershipHistory[]      @relation("OwnershipChangedBy")
  escalatedSla                    SlaRule[]
  assignedTickets                 Ticket[]
  ticketComments                  TicketComment[]
  knowledgeArticles               KnowledgeArticle[]
  copilotConversations            CopilotConversation[]
  savedReports                    SavedReport[]
  callLogs                        CallLog[]
  notifications                   Notification[]
  devices                         Device[]
  eventAssignments                EventTeamAssignment[]
  leaveRequests                   LeaveRequest[]              @relation("LeaveRequestUser")
  approvedLeaveRequests           LeaveRequest[]              @relation("LeaveRequestApprover")
  salaryRecords                   SalaryRecord[]
  timesheetEntries                TimesheetEntry[]
  modulePermissions               ModulePermission[]          @relation("ModulePermissionUser")
  customFieldValues               CustomFieldValue[]          @relation("CustomFieldValueUser")
  assignedSiteVisits              SiteVisit[]                 @relation("AssignedSiteVisits")
  createdSiteVisits               SiteVisit[]                 @relation("CreatedSiteVisits")
  unitStatusChanges               UnitStatusHistory[]
  requestedUnitHolds              UnitHold[]                  @relation("UnitHoldRequestedBy")
  approvedUnitHolds               UnitHold[]                  @relation("UnitHoldApprovedBy")
  approvedInventoryReleaseBatches InventoryReleaseBatch[]
  salesTargets                    SalesTarget[]
  createdCostSheets               CostSheet[]                 @relation("CostSheetCreatedBy")
  approvedCostSheets              CostSheet[]                 @relation("CostSheetApprovedBy")
  requestedOffers                 Offer[]                     @relation("OfferRequestedBy")
  offerApprovals                  OfferApproval[]
  requestedBuyerDocuments         BuyerDocument[]             @relation("BuyerDocumentRequestedBy")
  verifiedBuyerDocuments          BuyerDocument[]             @relation("BuyerDocumentVerifiedBy")
  kycVerifications                KycVerification[]
  approvedDocumentTemplates       DocumentTemplate[]
  generatedDocuments              GeneratedDocument[]
  confirmedPaymentReceipts        PaymentReceipt[]            @relation("PaymentReceiptConfirmedBy")
  ledgerEntriesCreated            LedgerEntry[]
  decidedPartnerLeadClaims        PartnerLeadClaim[]
  approvedCommissionAccruals      CommissionAccrual[]
  approvedCommissionPayouts       CommissionPayout[]
  escalatedSlaBreaches            SlaBreach[]
  requestedApprovals              ApprovalRequest[]           @relation("ApprovalRequestedBy")
  decidedApprovals                ApprovalRequest[]           @relation("ApprovalDecidedBy")
  confirmedBookings               Booking[]                   @relation("BookingConfirmedBy")
  bookingStatusChanges            BookingStatusHistoryEntry[]
  physicalDocumentCheckouts       PhysicalDocumentCustody[]   @relation("PhysicalDocumentCheckedOutBy")
  postSalesTransitionsChanged     PostSalesTransition[]
  transferCasesRequested          TransferCase[]              @relation("TransferRequestedBy")
  transferCasesApproved           TransferCase[]              @relation("TransferApprovedBy")
  unitShiftCasesRequested         UnitShiftCase[]             @relation("UnitShiftRequestedBy")
  unitShiftCasesApproved          UnitShiftCase[]             @relation("UnitShiftApprovedBy")
  cancellationCasesRequested      CancellationCase[]          @relation("CancellationRequestedBy")
  cancellationCasesApproved       CancellationCase[]          @relation("CancellationApprovedBy")
  refundCasesRequested            RefundCase[]                @relation("RefundRequestedBy")
  refundCasesApproved             RefundCase[]                @relation("RefundApprovedBy")
  possessionCasesAcknowledged     PossessionCase[]
  creditNotesApproved             CreditNote[]
  department                      String?
  salaryType                      String?
  monthlySalary                   Float?
  joinedDate                      DateTime?
  skills                          String[]                    @default([])
  annualLeaveQuota                Int?
  teamStatus                      String?

  @@index([email])
  @@index([role])
  @@map("users")
}

model BusinessSettings {
  id                    String   @id @default(uuid())
  // Enforces a single row at the DB level (upsert on this unique field is atomic),
  // instead of relying on an app-level find-then-create check that two concurrent
  // callers (e.g. boot-time config reconcile racing an API request) could both pass.
  singleton             Boolean  @unique @default(true)
  businessName          String   @default("")
  timezone              String   @default("UTC")
  defaultCurrency       String   @default("USD")
  defaultWhatsAppNumber String?
  defaultEmail          String?
  defaultCrm            String?
  defaultBookingTool    String?
  workingHoursStart     String?
  workingHoursEnd       String?
  quietHoursStart       String? // e.g. "21:00"
  quietHoursEnd         String? // e.g. "09:00"
  autonomyLevel         String   @default("full") // shadow | approval | full
  consentRequired       Boolean  @default(true)
  maxMessagesPerDay     Int      @default(10)
  notificationEmail     String?
  notificationPhone     String?
  logoUrl               String?
  faviconUrl            String?
  primaryColor          String   @default("#0B5")
  labels                Json     @default("{}")
  industry              String?
  toneExamples          String[] @default([])
  goals                 String[] @default([])
  compliance            String[] @default([])
  inventoryEnforcement  String   @default("ADVISORY") // ADVISORY | STRICT — governs event inventory over-allocation
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("business_settings")
}

model Contact {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
  version          Int       @default(0)
  deletedAt        DateTime?
  name             String?
  email            String?
  phone            String?
  whatsapp         String?
  company          String?
  location         String?
  preferredChannel String?
  metadata         Json      @default("{}")
  tags             String[]  @default([])
  consentStatus    String    @default("unknown") // unknown | opted_in | opted_out
  consentSource    String?
  consentAt        DateTime?
  optedOutAt       DateTime?
  agentMemory      Json? // Bounded summary for the LLM agent
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  leads               Lead[]
  conversations       ConversationMessage[]
  mediaFiles          MediaFile[]           @relation("ContactMedia")
  customFields        CustomFieldValue[]
  systemEvents        SystemEvent[]
  timelineItems       TimelineItem[]
  consentEvents       ConsentEvent[]
  tickets             Ticket[]
  callLogs            CallLog[]
  events              Event[]
  invoices            Invoice[]
  quotations          Quotation[]
  contracts           Contract[]
  bookingApplicant    BookingApplicant[]
  buyerPortalTokens   BuyerPortalToken[]
  referralsAsReferrer Referral[]            @relation("ReferrerContact")
  transferCasesFrom   TransferCase[]        @relation("TransferFromApplicant")
  transferCasesTo     TransferCase[]        @relation("TransferToApplicant")

  @@index([email])
  @@index([phone])
  @@index([whatsapp])
  @@map("contacts")
}

model Lead {
  id          String      @id @default(uuid())
  tenantId    String      @map("tenant_id")
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  version     Int         @default(0)
  deletedAt   DateTime?
  status      LeadStatus  @default(NEW)
  segment     LeadSegment @default(COLD)
  source      LeadSource
  score       Int         @default(0)
  priority    Int         @default(0)
  interest    String?
  budget      String?
  dealValue   Float?
  urgency     String?
  message     String?
  tags        String[]    @default([])
  metadata    Json        @default("{}")
  campaignId  String?
  qualifiedAt DateTime?
  convertedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  contactId       String
  contact         Contact @relation(fields: [contactId], references: [id])
  assignedAgentId String?
  assignedAgent   User?   @relation(fields: [assignedAgentId], references: [id])

  campaign                    Campaign?                    @relation(fields: [campaignId], references: [id])
  conversations               ConversationMessage[]
  mediaFiles                  MediaFile[]                  @relation("LeadMedia")
  nurtureProgress             NurtureProgress[]
  tasks                       Task[]
  conversions                 Conversion[]
  scoreLogs                   ScoreLog[]
  customFields                CustomFieldValue[]
  ownershipHistory            LeadOwnershipHistory[]
  internalNotes               InternalNote[]
  revenueRecords              RevenueRecord[]
  submissions                 FormSubmission[]
  systemEvents                SystemEvent[]
  timelineItems               TimelineItem[]
  failureRecords              FailureRecord[]
  workflowInstances           WorkflowInstance[]
  scheduledActions            ScheduledAction[]
  tickets                     Ticket[]
  callLogs                    CallLog[]
  events                      Event[]
  bookings                    Booking[]
  shipments                   Shipment[]
  paymentSchedules            PaymentSchedule[]
  bookedUnits                 Unit[]
  siteVisits                  SiteVisit[]
  unitHolds                   UnitHold[]
  costSheets                  CostSheet[]
  offers                      Offer[]
  buyerDocuments              BuyerDocument[]
  kycVerifications            KycVerification[]
  generatedDocuments          GeneratedDocument[]
  paymentReceipts             PaymentReceipt[]
  ledgerEntries               LedgerEntry[]
  partnerLeadClaims           PartnerLeadClaim[]
  slaBreaches                 SlaBreach[]
  marketingJourneyEnrollments MarketingJourneyEnrollment[]
  marketingEventInvitees      MarketingEventInvitee[]
  referralsAsReferred         Referral[]                   @relation("ReferredLead")
  nriProfile                  NriBuyerProfile?
  physicalDocumentCustodies   PhysicalDocumentCustody[]    @relation("PhysicalDocumentLead")
  buyerSessions               BuyerSession[]

  channelPartnerId String?
  channelPartner   ChannelPartner? @relation(fields: [channelPartnerId], references: [id])

  @@index([status])
  @@index([segment])
  @@index([score])
  @@index([source])
  @@index([campaignId])
  @@index([assignedAgentId])
  @@index([contactId])
  @@index([createdAt])
  @@index([channelPartnerId])
  @@map("leads")
}

model ConsentEvent {
  id        String   @id @default(uuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel   String // whatsapp | email | sms | all
  action    String // opt_in | opt_out
  source    String? // webhook | form | agent | manual
  createdAt DateTime @default(now())

  @@index([contactId])
  @@map("consent_events")
}

model Campaign {
  id           String     @id @default(uuid())
  tenantId     String     @map("tenant_id")
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  name         String
  description  String?
  sourceType   LeadSource
  campaignType String     @default("multi-channel")

  // Offer & destination
  offer              String?
  landingUrl         String?
  conversionGoal     String?
  crmDestination     String?
  bookingDestination String?

  // Status & schedule
  active    Boolean   @default(true)
  status    String    @default("draft") // draft, active, paused, completed, archived
  startDate DateTime?
  endDate   DateTime?
  priority  Int       @default(0)

  // Budget: { total: number, daily: number, spent: number, currency: string }
  budget Json @default("{}")

  // Targeting: { propertyTypes: string[], budgetRanges: string[], locations: string[], buyerType: string, minScore: number }
  targeting Json @default("{}")

  // Channels: [{ type: string, config: {}, active: boolean }]
  channels Json @default("[]")

  // Creatives: [{ name, type, headline, body, cta, imageUrl, thumbnailUrl, variant, performance: { impressions, clicks, conversions } }]
  creatives Json @default("[]")

  // UTM
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?

  // Metrics (computed/updated by performance endpoint)
  totalBudget      Float? @default(0)
  dailyBudget      Float? @default(0)
  totalSpend       Float? @default(0)
  costPerLead      Float?
  roi              Float?
  totalLeads       Int    @default(0)
  totalConversions Int    @default(0)

  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorId       String
  creator         User                    @relation("CampaignCreator", fields: [creatorId], references: [id])
  assignedAgentId String?
  assignedAgent   User?                   @relation("CampaignAssignee", fields: [assignedAgentId], references: [id])
  formId          String?
  form            LeadForm?               @relation(fields: [formId], references: [id])
  qrCodeId        String?
  qrCode          QrCode?                 @relation(fields: [qrCodeId], references: [id])
  nurtureId       String?
  nurtureSequence NurtureSequence?        @relation(fields: [nurtureId], references: [id])
  leads           Lead[]
  mediaFiles      MediaFile[]             @relation("CampaignMedia")
  conversations   ConversationMessage[]
  timeline        CampaignTimelineEntry[]

  @@index([active])
  @@index([sourceType])
  @@index([status])
  @@map("campaigns")
}

model CampaignTimelineEntry {
  id         String   @id @default(uuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  event      String // created, activated, paused, completed, budget_changed, creative_added, etc.
  detail     String?
  metadata   Json     @default("{}")
  userId     String?
  createdAt  DateTime @default(now())

  @@map("campaign_timeline")
}

model LeadForm {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-step config: array of { id, title, description }
  steps Json @default("[]")

  // Embed config: { type: 'inline'|'popup'|'slide', theme: {...} }
  embedConfig Json @default("{}")

  // Post-submission: { redirectUrl, confirmationMessage, sendConfirmationEmail, emailTemplateId }
  submissionConfig Json @default("{}")

  // Form type hint for template selection
  formType String @default("custom")

  fields      LeadFormField[]
  submissions FormSubmission[]
  campaigns   Campaign[]

  @@map("lead_forms")
}

model LeadFormField {
  id           String  @id @default(uuid())
  label        String
  fieldKey     String
  type         String
  required     Boolean @default(false)
  placeholder  String?
  description  String?
  validation   Json    @default("{}")
  options      Json    @default("[]")
  displayOrder Int     @default(0)

  // Multi-step: which step this field belongs to
  stepId String @default("")

  // Conditional logic: { action: 'show'|'hide'|'require', conditions: [{ fieldKey, operator: 'eq'|'neq'|'gt'|'lt'|'in'|'contains', value }] }
  conditionalLogic Json @default("{}")

  // Layout: width (full/half/third), icon
  width String @default("full")

  formId String
  form   LeadForm @relation(fields: [formId], references: [id])

  @@map("lead_form_fields")
}

model FormSubmission {
  id      String   @id @default(uuid())
  payload Json
  formId  String
  form    LeadForm @relation(fields: [formId], references: [id])
  leadId  String?
  lead    Lead?    @relation(fields: [leadId], references: [id])

  // Source tracking
  source  String  @default("direct")
  pageUrl String?
  utm     Json    @default("{}")

  // Completion tracking
  completed   Boolean   @default(true)
  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@map("form_submissions")
}

model QrCode {
  id              String   @id @default(uuid())
  name            String
  destinationType String
  destination     String
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  scans     QrScan[]
  campaigns Campaign[]

  @@map("qr_codes")
}

model QrScan {
  id        String   @id @default(uuid())
  qrCodeId  String
  qrCode    QrCode   @relation(fields: [qrCodeId], references: [id])
  country   String?
  city      String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([qrCodeId])
  @@map("qr_scans")
}

model ConversationMessage {
  id                String           @id @default(uuid())
  text              String
  providerMessageId String?
  deliveryStatus    String           @default("pending")
  channel           MessageChannel
  direction         MessageDirection
  metadata          Json             @default("{}")
  messageTemplateId String?
  messageTemplate   MessageTemplate? @relation(fields: [messageTemplateId], references: [id])
  leadId            String
  lead              Lead             @relation(fields: [leadId], references: [id])
  contactId         String?
  contact           Contact?         @relation(fields: [contactId], references: [id])
  campaignId        String?
  campaign          Campaign?        @relation(fields: [campaignId], references: [id])
  createdAt         DateTime         @default(now())

  @@index([leadId])
  @@index([contactId, createdAt])
  @@index([campaignId])
  @@index([providerMessageId])
  @@index([channel])
  @@index([direction])
  @@map("conversation_messages")
}

model MessageTemplate {
  id        String              @id @default(uuid())
  name      String
  type      MessageTemplateType
  channel   MessageChannel
  body      String
  variables Json                @default("[]")
  version   Int                 @default(1)
  active    Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  creatorId        String
  creator          User                  @relation(fields: [creatorId], references: [id])
  mediaFiles       MediaFile[]           @relation("TemplateMedia")
  conversationMsgs ConversationMessage[]
  nurtureSteps     NurtureStep[]

  @@map("message_templates")
}

model MediaCollection {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  name          String
  description   String?
  coverImageUrl String?
  projectId     String?
  propertyId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant                @relation(fields: [tenantId], references: [id])
  items  MediaCollectionItem[]

  @@index([tenantId])
  @@map("media_collections")
}

model MediaCollectionItem {
  id           String          @id @default(uuid())
  collectionId String
  collection   MediaCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  mediaId      String
  media        MediaFile       @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  orderIndex   Int             @default(0)
  createdAt    DateTime        @default(now())

  @@unique([collectionId, mediaId])
  @@index([mediaId])
  @@map("media_collection_items")
}

model MediaFile {
  id                String        @id @default(uuid())
  fileName          String
  originalName      String
  fileType          String
  mimeType          String
  fileSize          Int
  storageProvider   String        @default("local")
  storageKey        String
  publicUrl         String?
  signedUrl         String?
  category          MediaCategory @default(OTHER)
  tags              String[]      @default([])
  isDigitalDownload Boolean       @default(false)
  downloadStatus    String?
  projectId         String?
  propertyId        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  uploadedById          String
  uploadedBy            User                      @relation("MediaUploader", fields: [uploadedById], references: [id])
  leadId                String?
  lead                  Lead?                     @relation("LeadMedia", fields: [leadId], references: [id])
  campaignId            String?
  campaign              Campaign?                 @relation("CampaignMedia", fields: [campaignId], references: [id])
  contactId             String?
  contact               Contact?                  @relation("ContactMedia", fields: [contactId], references: [id])
  templateId            String?
  template              MessageTemplate?          @relation("TemplateMedia", fields: [templateId], references: [id])
  collections           MediaCollectionItem[]
  buyerDocuments        BuyerDocument[]
  generatedDocuments    GeneratedDocument[]
  paymentReceipts       PaymentReceipt[]
  physicalDocumentScans PhysicalDocumentCustody[] @relation("PhysicalDocumentScanMedia")

  @@index([category])
  @@index([fileType])
  @@index([createdAt])
  @@index([leadId])
  @@index([campaignId])
  @@index([templateId])
  @@index([projectId])
  @@index([propertyId])
  @@map("media_files")
}

model NurtureSequence {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps     NurtureStep[]
  campaigns Campaign[]
  progress  NurtureProgress[]

  @@map("nurture_sequences")
}

model NurtureStep {
  id           String           @id @default(uuid())
  sequenceId   String
  sequence     NurtureSequence  @relation(fields: [sequenceId], references: [id])
  type         NurtureStepType
  displayOrder Int
  config       Json             @default("{}")
  templateId   String?
  template     MessageTemplate? @relation(fields: [templateId], references: [id])
  waitSeconds  Int              @default(0)
  condition    Json             @default("{}")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("nurture_steps")
}

model NurtureProgress {
  id         String          @id @default(uuid())
  leadId     String
  lead       Lead            @relation(fields: [leadId], references: [id])
  sequenceId String
  sequence   NurtureSequence @relation(fields: [sequenceId], references: [id])
  stepId     String
  status     String          @default("pending")
  dueAt      DateTime?
  executedAt DateTime?
  error      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([leadId])
  @@index([sequenceId])
  @@index([status])
  @@map("nurture_progress")
}

model ScoringRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  field       String
  operator    String
  value       String
  points      Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("scoring_rules")
}

model ScoreLog {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  ruleId    String?
  oldScore  Int
  newScore  Int
  reason    String?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@map("score_logs")
}

model RoutingRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  conditions  Json
  action      Json
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("routing_rules")
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("pending")
  priority    String    @default("medium")
  dueAt       DateTime?
  leadId      String?
  lead        Lead?     @relation(fields: [leadId], references: [id])
  assigneeId  String?
  assignee    User?     @relation(fields: [assigneeId], references: [id])
  eventId     String?
  event       Event?    @relation(fields: [eventId], references: [id])
  createdBy   String    @default("agent")
  source      String    @default("manual")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([assigneeId])
  @@index([leadId])
  @@index([eventId])
  @@map("tasks")
}

model Conversion {
  id            String                @id @default(uuid())
  destination   ConversionDestination
  status        ConversionStatus      @default(REQUESTED)
  externalId    String?
  metadata      Json                  @default("{}")
  leadId        String
  lead          Lead                  @relation(fields: [leadId], references: [id])
  requestedById String?
  scheduledAt   DateTime?
  duration      Int?
  notes         String?
  completedAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([leadId])
  @@index([destination])
  @@index([status])
  @@map("conversions")
}

// === PROPERTY / LISTING (Real Estate) ===

enum PropertyType {
  APARTMENT
  VILLA
  PLOT
  COMMERCIAL
  PENTHOUSE
  DUPLEX
  STUDIO

  @@map("property_type")
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  UNDER_OFFER
  ON_HOLD
  RENTED
  DRAFT

  @@map("property_status")
}

model Property {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  deletedAt     DateTime?
  title         String
  description   String?
  propertyType  PropertyType   @default(APARTMENT)
  status        PropertyStatus @default(AVAILABLE)
  price         Float?
  currency      String         @default("INR")
  bedrooms      Int?
  bathrooms     Int?
  areaSqft      Float?
  areaUnit      String         @default("sqft")
  location      String?
  address       String?
  latitude      Float?
  longitude     Float?
  features      String[]       @default([])
  amenities     String[]       @default([])
  reraId        String?
  metadata      Json           @default("{}")
  featured      Boolean        @default(false)
  availableFrom DateTime?
  brochureUrl   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  images   PropertyImage[]
  bookings Booking[]

  @@index([tenantId])
  @@index([propertyType])
  @@index([status])
  @@index([price])
  @@index([location])
  @@index([bedrooms])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  isPrimary  Boolean  @default(false)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([propertyId])
  @@map("property_images")
}

enum ProjectStatus {
  PLANNING
  UNDER_CONSTRUCTION
  READY_TO_MOVE
  COMPLETED

  @@map("project_status")
}

enum UnitStatus {
  AVAILABLE
  BLOCKED
  BOOKED
  SOLD
  ON_HOLD

  @@map("unit_status")
}

/// A builder's development — sold as units inside towers/floors, not flat
/// listings. Separate from Property (broker/resale flat listings) because a
/// builder's inventory has structure (tower → floor → unit) that a broker's
/// standalone listings never need.
model Project {
  id             String        @id @default(uuid())
  tenantId       String        @map("tenant_id")
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  deletedAt      DateTime?
  name           String
  description    String?
  location       String?
  address        String?
  reraId         String?
  status         ProjectStatus @default(UNDER_CONSTRUCTION)
  possessionDate DateTime?
  amenities      String[]      @default([])
  images         Json          @default("[]")
  brochureUrl    String?
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  towers                       Tower[]
  units                        Unit[]
  siteVisits                   SiteVisit[]
  costSheets                   CostSheet[]
  marketingEvents              MarketingEvent[]
  cashFlowForecastEntries      CashFlowForecastEntry[]
  revenueShareParties          RevenueShareParty[]
  constructionErpConnections   ConstructionErpConnection[]
  constructionMilestoneUpdates ConstructionMilestoneUpdate[]
  territoryAssignments         TerritoryAssignment[]
  phases                       ProjectPhase[]
  alliedInventoryItems         AlliedInventoryItem[]
  inventoryReleaseBatches      InventoryReleaseBatch[]
  landingPages                 LandingPage[]
  salesTargets                 SalesTarget[]
  buyerSessions                BuyerSession[]
  adSpendImports               AdSpendImport[]

  @@index([tenantId])
  @@index([status])
  @@map("projects")
}

/// Optional grouping between Project and Tower for builders who sell in phases —
/// a phase controls its own inventory-release timing independent of the rest of the project (spec 63.2).
model ProjectPhase {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  status    String   @default("PLANNED")
  createdAt DateTime @default(now())

  towers         Tower[]
  releaseBatches InventoryReleaseBatch[]

  @@index([tenantId])
  @@index([projectId])
  @@map("project_phases")
}

/// Scopes which projects (territories) a user can see/act on; absence of any row for a user means unrestricted (managers/admins).
model TerritoryAssignment {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([tenantId])
  @@index([projectId])
  @@map("territory_assignments")
}

enum SalesTargetScope {
  TENANT
  PROJECT
  TEAM
  AGENT

  @@map("sales_target_scope")
}

enum SalesTargetMetric {
  LEAD_RESPONSE
  SITE_VISITS
  BOOKINGS
  AGREEMENT_VALUE_PAISE
  COLLECTIONS_PAISE

  @@map("sales_target_metric")
}

/// A monthly/quarterly quota against a scope (tenant/project/team/agent) and
/// metric — comparisons must always show the scope so an agent with a small
/// territory isn't unfairly measured against one with a large one (spec 65.2).
model SalesTarget {
  id          String            @id @default(uuid())
  tenantId    String            @map("tenant_id")
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  scope       SalesTargetScope
  projectId   String?
  project     Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  metric      SalesTargetMetric
  periodStart DateTime
  periodEnd   DateTime
  targetValue Float
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([tenantId])
  @@index([projectId])
  @@index([userId])
  @@index([periodStart, periodEnd])
  @@map("sales_targets")
}

model Tower {
  id          String        @id @default(uuid())
  projectId   String
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phaseId     String?
  phase       ProjectPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  name        String
  totalFloors Int?
  createdAt   DateTime      @default(now())

  units                        Unit[]
  constructionMilestoneUpdates ConstructionMilestoneUpdate[]
  alliedInventoryItems         AlliedInventoryItem[]

  @@index([projectId])
  @@index([phaseId])
  @@map("towers")
}

enum AlliedInventoryType {
  PARKING
  STORAGE
  TERRACE
  SERVANT_ROOM
  OTHER

  @@map("allied_inventory_type")
}

enum AlliedInventoryStatus {
  AVAILABLE
  ALLOCATED
  BLOCKED

  @@map("allied_inventory_status")
}

/// A sellable/allocatable item that isn't a Unit itself — parking bay, storage,
/// terrace. Allocated to a booking through InventoryAllocation, never encoded
/// as a free-text note on the unit (spec 63.2).
model AlliedInventoryItem {
  id          String                @id @default(uuid())
  tenantId    String                @map("tenant_id")
  tenant      Tenant                @relation(fields: [tenantId], references: [id])
  projectId   String
  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  towerId     String?
  tower       Tower?                @relation(fields: [towerId], references: [id], onDelete: SetNull)
  type        AlliedInventoryType
  label       String
  priceRupees Float?
  status      AlliedInventoryStatus @default(AVAILABLE)
  createdAt   DateTime              @default(now())

  allocations AlliedInventoryAllocation[]

  @@index([tenantId])
  @@index([projectId])
  @@index([status])
  @@map("allied_inventory_items")
}

/// Links an AlliedInventoryItem to the Booking it was sold with — an explicit
/// join row instead of a free-text note (spec 63.2). Named distinctly from
/// the unrelated procurement `InventoryAllocation` (event/InventoryItem) model.
model AlliedInventoryAllocation {
  id             String              @id @default(uuid())
  tenantId       String              @map("tenant_id")
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  itemId         String              @unique
  item           AlliedInventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  bookingId      String
  booking        Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  pricePaidPaise BigInt?
  createdAt      DateTime            @default(now())

  @@index([tenantId])
  @@index([bookingId])
  @@map("allied_inventory_allocations")
}

enum InventoryReleaseBatchStatus {
  PLANNED
  RELEASED
  CANCELLED

  @@map("inventory_release_batch_status")
}

/// A controlled, audited launch-day inventory release — turns "opening a
/// spreadsheet" into a governed action with an approver and a fixed unit list
/// (spec 63.2/63.3).
model InventoryReleaseBatch {
  id           String                      @id @default(uuid())
  tenantId     String                      @map("tenant_id")
  tenant       Tenant                      @relation(fields: [tenantId], references: [id])
  projectId    String
  project      Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phaseId      String?
  phase        ProjectPhase?               @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  name         String
  unitIds      String[]                    @default([])
  releaseAt    DateTime
  status       InventoryReleaseBatchStatus @default(PLANNED)
  approvedById String?
  approvedBy   User?                       @relation(fields: [approvedById], references: [id])
  releasedAt   DateTime?
  createdById  String?
  createdAt    DateTime                    @default(now())

  @@index([tenantId])
  @@index([projectId])
  @@index([status])
  @@map("inventory_release_batches")
}

/// A single sellable unit inside a project (optionally inside a tower). The
/// availability grid and inventory velocity are both derived from this table's
/// status + statusHistory — no spreadsheet needed.
model Unit {
  id         String     @id @default(uuid())
  tenantId   String     @map("tenant_id")
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  towerId    String?
  tower      Tower?     @relation(fields: [towerId], references: [id], onDelete: SetNull)
  unitNumber String
  floor      Int?
  unitType   String?
  areaSqft   Float?
  price      Float?
  currency   String     @default("INR")
  status     UnitStatus @default(AVAILABLE)
  facing     String?
  leadId     String?
  lead       Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  bookedAt   DateTime?
  soldAt     DateTime?
  version    Int        @default(0)
  metadata   Json       @default("{}")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  statusHistory           UnitStatusHistory[]
  bookings                Booking[]
  siteVisits              SiteVisit[]
  holds                   UnitHold[]
  costSheets              CostSheet[]
  revenueShareAllocations RevenueShareAllocation[]
  resaleListings          ResaleListing[]
  unitShiftCasesFrom      UnitShiftCase[]          @relation("UnitShiftFrom")
  unitShiftCasesTo        UnitShiftCase[]          @relation("UnitShiftTo")
  checkoutHolds           CheckoutHold[]
  shortlists              UnitShortlist[]
  checkoutAttempts        CheckoutAttempt[]

  @@unique([projectId, unitNumber])
  @@index([tenantId])
  @@index([projectId])
  @@index([towerId])
  @@index([status])
  @@index([leadId])
  @@map("units")
}

/// Every status transition a unit goes through, timestamped — this is what
/// makes "units sold this month" a real query instead of a manual count.
model UnitStatusHistory {
  id          String      @id @default(uuid())
  unitId      String
  unit        Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  fromStatus  UnitStatus?
  toStatus    UnitStatus
  reason      String?
  changedById String?
  changedBy   User?       @relation(fields: [changedById], references: [id], onDelete: SetNull)
  changedAt   DateTime    @default(now())

  @@index([unitId])
  @@index([changedAt])
  @@map("unit_status_history")
}

enum UnitHoldStatus {
  ACTIVE
  RELEASED
  EXPIRED
  CONSUMED

  @@map("unit_hold_status")
}

/// A concurrency-safe, time-boxed reservation of a Unit for a Lead — the
/// atomic-hold algorithm (spec 48.7) relies on Unit.version so two
/// salespeople racing to hold the same unit can't both succeed.
model UnitHold {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  unitId        String
  unit          Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  leadId        String
  lead          Lead           @relation(fields: [leadId], references: [id])
  requestedById String?
  requestedBy   User?          @relation("UnitHoldRequestedBy", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    User?          @relation("UnitHoldApprovedBy", fields: [approvedById], references: [id])
  status        UnitHoldStatus @default(ACTIVE)
  expiresAt     DateTime
  releasedAt    DateTime?
  releaseReason String?
  metadata      Json           @default("{}")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([tenantId, status])
  @@index([unitId, status])
  @@index([leadId])
  @@index([expiresAt])
  @@map("unit_holds")
}

enum CostSheetStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  EXPIRED
  SUPERSEDED

  @@map("cost_sheet_status")
}

/// A versioned, snapshotted price breakdown for one unit/buyer (spec 48.8).
/// Money is stored in paise (Int) per the project's money-handling contract —
/// never float — so later price changes can never silently alter a sheet
/// that has already been sent to a buyer.
model CostSheet {
  id              String          @id @default(uuid())
  tenantId        String          @map("tenant_id")
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  leadId          String
  lead            Lead            @relation(fields: [leadId], references: [id])
  unitId          String
  unit            Unit            @relation(fields: [unitId], references: [id])
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id])
  status          CostSheetStatus @default(DRAFT)
  currency        String          @default("INR")
  totalPaise      BigInt
  templateVersion Int             @default(1)
  snapshot        Json            @default("{}")
  createdById     String?
  createdBy       User?           @relation("CostSheetCreatedBy", fields: [createdById], references: [id])
  approvedById    String?
  approvedBy      User?           @relation("CostSheetApprovedBy", fields: [approvedById], references: [id])
  expiresAt       DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  lineItems CostSheetLineItem[]
  offers    Offer[]
  bookings  Booking[]

  @@index([tenantId, status])
  @@index([leadId])
  @@index([unitId])
  @@map("cost_sheets")
}

model CostSheetLineItem {
  id              String    @id @default(uuid())
  costSheetId     String
  costSheet       CostSheet @relation(fields: [costSheetId], references: [id], onDelete: Cascade)
  code            String
  label           String
  calculationType String    @default("FLAT") // FLAT | PER_SQFT | PERCENT
  amountPaise     BigInt
  taxable         Boolean   @default(false)
  displayOrder    Int       @default(0)
  metadata        Json      @default("{}")

  @@index([costSheetId])
  @@map("cost_sheet_line_items")
}

enum OfferStatus {
  PENDING
  APPROVED
  REJECTED
  REVISED
  EXPIRED

  @@map("offer_status")
}

/// A requested discount/negotiation against a CostSheet, gated by an approval
/// chain (spec 48.8) — sales can request, but only a manager/owner within
/// policy can approve.
model Offer {
  id                   String      @id @default(uuid())
  tenantId             String      @map("tenant_id")
  tenant               Tenant      @relation(fields: [tenantId], references: [id])
  costSheetId          String
  costSheet            CostSheet   @relation(fields: [costSheetId], references: [id])
  leadId               String
  lead                 Lead        @relation(fields: [leadId], references: [id])
  requestedById        String?
  requestedBy          User?       @relation("OfferRequestedBy", fields: [requestedById], references: [id])
  discountPaise        BigInt?
  discountPercent      Float?
  reason               String?
  proposedValuePaise   BigInt?
  policyThresholdPaise BigInt?
  status               OfferStatus @default(PENDING)
  expiresAt            DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  approvals OfferApproval[]

  @@index([tenantId, status])
  @@index([costSheetId])
  @@index([leadId])
  @@map("offers")
}

enum OfferDecision {
  APPROVED
  REJECTED

  @@map("offer_decision")
}

model OfferApproval {
  id         String        @id @default(uuid())
  offerId    String
  offer      Offer         @relation(fields: [offerId], references: [id], onDelete: Cascade)
  approverId String?
  approver   User?         @relation(fields: [approverId], references: [id])
  decision   OfferDecision
  reason     String?
  decidedAt  DateTime      @default(now())

  @@index([offerId])
  @@map("offer_approvals")
}

enum SiteVisitStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  NO_SHOW
  RESCHEDULED
  CANCELLED

  @@map("site_visit_status")
}

/// A dedicated model for a buyer visiting a project/unit in person — kept
/// separate from Booking (which represents the purchase/agreement side) per
/// the sell-do-small-builder spec section 48.6. Legacy site-visit-shaped rows
/// living in Booking are left as-is; this model is used for all NEW visits.
model SiteVisit {
  id              String  @id @default(uuid())
  tenantId        String  @map("tenant_id")
  tenant          Tenant  @relation(fields: [tenantId], references: [id])
  leadId          String
  lead            Lead    @relation(fields: [leadId], references: [id])
  projectId       String
  project         Project @relation(fields: [projectId], references: [id])
  unitId          String?
  unit            Unit?   @relation(fields: [unitId], references: [id], onDelete: SetNull)
  assignedAgentId String?
  assignedAgent   User?   @relation("AssignedSiteVisits", fields: [assignedAgentId], references: [id])
  createdById     String?
  createdBy       User?   @relation("CreatedSiteVisits", fields: [createdById], references: [id])

  startAt             DateTime
  endAt               DateTime?
  status              SiteVisitStatus @default(SCHEDULED)
  meetingPoint        String?
  mapsUrl             String?
  attendeeCount       Int?
  transportNote       String?
  language            String?
  confirmationChannel String?

  confirmationAt DateTime?
  checkedInAt    DateTime?
  checkedOutAt   DateTime?

  outcome          Json?     @default("{}")
  noShowReason     String?
  rescheduleReason String?
  nextActionAt     DateTime?

  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances VisitAttendance[]

  @@index([tenantId, status, startAt])
  @@index([leadId])
  @@index([assignedAgentId])
  @@index([projectId])
  @@map("site_visits")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW

  @@map("booking_status")
}

model Booking {
  id            String        @id @default(uuid())
  tenantId      String
  leadId        String
  propertyId    String?       @map("property_id")
  unitId        String?
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime?
  status        BookingStatus @default(PENDING)
  price         Float?
  currency      String        @default("INR")
  paymentLink   String?
  paymentStatus String        @default("pending")
  notes         String?
  metadata      Json          @default("{}")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Purchase-booking extension (spec 48.9) — a Booking that represents an
  // actual unit sale (as opposed to a legacy calendar-event-style booking)
  // carries these. version enables optimistic-lock confirmation.
  costSheetId        String?
  costSheet          CostSheet? @relation(fields: [costSheetId], references: [id])
  bookingNumber      String?    @unique
  bookingAmountPaise BigInt?
  confirmedById      String?
  confirmedByUser    User?      @relation("BookingConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt        DateTime?
  cancellationReason String?
  version            Int        @default(0)

  // Post-sales lifecycle (spec 67.1) — only meaningful once status=CONFIRMED.
  // Kept as a separate field from `status` because a booking can be
  // CONFIRMED while its post-sales stage moves through many sub-states over
  // months; `status` stays the coarse PENDING/CONFIRMED/CANCELLED/etc lens.
  postSalesStage          PostSalesStage?
  postSalesStageChangedAt DateTime?

  lead                       Lead                        @relation(fields: [leadId], references: [id])
  tenant                     Tenant                      @relation(fields: [tenantId], references: [id])
  property                   Property?                   @relation(fields: [propertyId], references: [id])
  unit                       Unit?                       @relation(fields: [unitId], references: [id])
  paymentSchedules           PaymentSchedule[]
  buyerDocuments             BuyerDocument[]
  generatedDocuments         GeneratedDocument[]
  paymentReceipts            PaymentReceipt[]
  ledgerEntries              LedgerEntry[]
  commissionAccruals         CommissionAccrual[]
  applicants                 BookingApplicant[]
  statusHistory              BookingStatusHistoryEntry[]
  portalTokens               BuyerPortalToken[]
  revenueShareAllocations    RevenueShareAllocation[]
  physicalDocumentCustodies  PhysicalDocumentCustody[]
  postSalesTransitions       PostSalesTransition[]
  transferCases              TransferCase[]
  unitShiftCases             UnitShiftCase[]
  cancellationCases          CancellationCase[]
  refundCases                RefundCase[]
  possessionCase             PossessionCase?
  creditNotes                CreditNote[]
  loanRegistrationCase       LoanRegistrationCase?
  alliedInventoryAllocations AlliedInventoryAllocation[]
  checkoutAttempts           CheckoutAttempt[]

  @@index([tenantId])
  @@index([leadId])
  @@index([startTime])
  @@map("bookings")
}

enum PostSalesStage {
  BOOKING_CONFIRMED
  KYC_IN_PROGRESS
  ALLOTMENT_ISSUED
  AGREEMENT_IN_PROGRESS
  AGREEMENT_REGISTERED
  PAYMENT_ACTIVE
  PRE_POSSESSION
  POSSESSION_OFFERED
  HANDED_OVER
  POST_POSSESSION_SUPPORT

  @@map("post_sales_stage")
}

/// Every post-sales stage transition, with the precondition check result and
/// who/when — this is what makes the lifecycle auditable instead of a single
/// dropdown a manager could silently skip stages on (spec 67.1).
model PostSalesTransition {
  id                    String          @id @default(uuid())
  tenantId              String          @map("tenant_id")
  tenant                Tenant          @relation(fields: [tenantId], references: [id])
  bookingId             String
  booking               Booking         @relation(fields: [bookingId], references: [id])
  fromStage             PostSalesStage?
  toStage               PostSalesStage
  preconditionsSnapshot Json            @default("{}")
  reason                String?
  changedById           String?
  changedBy             User?           @relation(fields: [changedById], references: [id])
  changedAt             DateTime        @default(now())

  @@index([tenantId, bookingId])
  @@map("post_sales_transitions")
}

enum CaseStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  COMPLETED

  @@map("case_status")
}

/// Applicant/name transfer (spec 67.3) — a controlled case, not a direct edit
/// to BookingApplicant, so the old and new applicant identity, charges, and
/// approval chain all survive as history.
model TransferCase {
  id                     String     @id @default(uuid())
  tenantId               String     @map("tenant_id")
  tenant                 Tenant     @relation(fields: [tenantId], references: [id])
  bookingId              String
  booking                Booking    @relation(fields: [bookingId], references: [id])
  fromApplicantContactId String?
  fromApplicant          Contact?   @relation("TransferFromApplicant", fields: [fromApplicantContactId], references: [id])
  toApplicantName        String
  toApplicantContactId   String?
  toApplicant            Contact?   @relation("TransferToApplicant", fields: [toApplicantContactId], references: [id])
  toApplicantPanMasked   String?
  reason                 String?
  chargesPaise           BigInt?
  status                 CaseStatus @default(REQUESTED)
  requestedById          String?
  requestedBy            User?      @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedById           String?
  approvedBy             User?      @relation("TransferApprovedBy", fields: [approvedById], references: [id])
  requestedAt            DateTime   @default(now())
  decidedAt              DateTime?
  completedAt            DateTime?

  @@index([tenantId, bookingId])
  @@map("transfer_cases")
}

/// A buyer moving from one unit to another (spec 67.3) — both units'
/// inventory transitions happen atomically when completed, and the price
/// difference is recorded, not silently absorbed.
model UnitShiftCase {
  id                   String     @id @default(uuid())
  tenantId             String     @map("tenant_id")
  tenant               Tenant     @relation(fields: [tenantId], references: [id])
  bookingId            String
  booking              Booking    @relation(fields: [bookingId], references: [id])
  fromUnitId           String
  fromUnit             Unit       @relation("UnitShiftFrom", fields: [fromUnitId], references: [id])
  toUnitId             String
  toUnit               Unit       @relation("UnitShiftTo", fields: [toUnitId], references: [id])
  priceDifferencePaise BigInt?
  reason               String?
  status               CaseStatus @default(REQUESTED)
  requestedById        String?
  requestedBy          User?      @relation("UnitShiftRequestedBy", fields: [requestedById], references: [id])
  approvedById         String?
  approvedBy           User?      @relation("UnitShiftApprovedBy", fields: [approvedById], references: [id])
  requestedAt          DateTime   @default(now())
  decidedAt            DateTime?
  completedAt          DateTime?

  @@index([tenantId, bookingId])
  @@map("unit_shift_cases")
}

/// Booking cancellation (spec 67.3) — carries the policy snapshot and
/// computed deduction/refund so a later policy change never rewrites a
/// decision already made.
model CancellationCase {
  id                   String     @id @default(uuid())
  tenantId             String     @map("tenant_id")
  tenant               Tenant     @relation(fields: [tenantId], references: [id])
  bookingId            String
  booking              Booking    @relation(fields: [bookingId], references: [id])
  reason               String
  policySnapshot       Json       @default("{}")
  deductionAmountPaise BigInt?
  refundPayablePaise   BigInt?
  status               CaseStatus @default(REQUESTED)
  requestedById        String?
  requestedBy          User?      @relation("CancellationRequestedBy", fields: [requestedById], references: [id])
  approvedById         String?
  approvedBy           User?      @relation("CancellationApprovedBy", fields: [approvedById], references: [id])
  requestedAt          DateTime   @default(now())
  decidedAt            DateTime?
  completedAt          DateTime?

  refundCases RefundCase[]

  @@index([tenantId, bookingId])
  @@map("cancellation_cases")
}

enum RefundCaseStatus {
  REQUESTED
  APPROVED
  PROCESSING
  PAID
  REJECTED

  @@map("refund_case_status")
}

/// A refund payable to a buyer — separate from CancellationCase since a
/// refund can also arise from a simple overpayment, and bank-account
/// verification must happen before payment initiation (spec 67.3).
model RefundCase {
  id                  String            @id @default(uuid())
  tenantId            String            @map("tenant_id")
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  bookingId           String
  booking             Booking           @relation(fields: [bookingId], references: [id])
  cancellationCaseId  String?
  cancellationCase    CancellationCase? @relation(fields: [cancellationCaseId], references: [id])
  amountPaise         BigInt
  bankAccountVerified Boolean           @default(false)
  status              RefundCaseStatus  @default(REQUESTED)
  requestedById       String?
  requestedBy         User?             @relation("RefundRequestedBy", fields: [requestedById], references: [id])
  approvedById        String?
  approvedBy          User?             @relation("RefundApprovedBy", fields: [approvedById], references: [id])
  paymentReference    String?
  requestedAt         DateTime          @default(now())
  decidedAt           DateTime?
  paidAt              DateTime?

  @@index([tenantId, bookingId])
  @@map("refund_cases")
}

enum PossessionCaseStatus {
  NOT_STARTED
  PRECONDITIONS_PENDING
  READY
  OFFERED
  ACKNOWLEDGED
  HANDED_OVER

  @@map("possession_case_status")
}

/// Possession preconditions (spec 67.4/68.3) tracked explicitly so
/// "possession offered" is never just a date passing — every precondition
/// is a real boolean someone confirmed.
model PossessionCase {
  id                         String               @id @default(uuid())
  tenantId                   String               @map("tenant_id")
  tenant                     Tenant               @relation(fields: [tenantId], references: [id])
  bookingId                  String               @unique
  booking                    Booking              @relation(fields: [bookingId], references: [id])
  status                     PossessionCaseStatus @default(NOT_STARTED)
  accountClearanceConfirmed  Boolean              @default(false)
  documentClearanceConfirmed Boolean              @default(false)
  unitReadinessConfirmed     Boolean              @default(false)
  possessionOfferedAt        DateTime?
  possessionAcknowledgedAt   DateTime?
  possessionAcknowledgedById String?
  possessionAcknowledgedBy   User?                @relation(fields: [possessionAcknowledgedById], references: [id])
  keyHandoverAt              DateTime?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt

  @@index([tenantId])
  @@map("possession_cases")
}

enum BookingApplicantRole {
  PRIMARY
  CO_APPLICANT

  @@map("booking_applicant_role")
}

/// Buyer/co-applicant identity captured at booking time (spec 48.9). PAN is
/// stored only as a reference/masked value here — never the raw number in
/// plaintext logs or exports (spec 46.2).
model BookingApplicant {
  id              String               @id @default(uuid())
  bookingId       String
  booking         Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         Contact?             @relation(fields: [contactId], references: [id])
  role            BookingApplicantRole @default(PRIMARY)
  name            String
  panMasked       String?
  addressSnapshot Json                 @default("{}")
  createdAt       DateTime             @default(now())

  @@index([bookingId])
  @@map("booking_applicants")
}

/// Every Booking status transition, with reason and actor — mirrors
/// UnitStatusHistory so a purchase booking's lifecycle is fully auditable.
model BookingStatusHistoryEntry {
  id          String         @id @default(uuid())
  bookingId   String
  booking     Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fromStatus  BookingStatus?
  toStatus    BookingStatus
  reason      String?
  changedById String?
  changedBy   User?          @relation(fields: [changedById], references: [id])
  changedAt   DateTime       @default(now())

  @@index([bookingId])
  @@map("booking_status_history")
}

enum PaymentScheduleStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED

  @@map("payment_schedule_status")
}

/// A scheduled collection milestone/installment for a lead (optionally tied to a
/// booking) — e.g. real-estate booking amount, agreement, registration, possession.
/// Automated reminders are queued as ScheduledActions on create and cancelled on payment.
model PaymentSchedule {
  id        String                @id @default(uuid())
  tenantId  String                @map("tenant_id")
  tenant    Tenant                @relation(fields: [tenantId], references: [id])
  leadId    String
  lead      Lead                  @relation(fields: [leadId], references: [id])
  bookingId String?
  booking   Booking?              @relation(fields: [bookingId], references: [id])
  label     String
  amount    Float
  currency  String                @default("INR")
  dueDate   DateTime?
  status    PaymentScheduleStatus @default(PENDING)
  paidAt    DateTime?
  notes     String?
  metadata  Json                  @default("{}")
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  allocations PaymentAllocation[]

  @@index([tenantId])
  @@index([leadId])
  @@index([bookingId])
  @@index([status])
  @@index([dueDate])
  @@map("payment_schedules")
}

enum ChannelPartnerOnboardingStatus {
  INVITED
  DOCS_PENDING
  TRAINING_PENDING
  ACTIVE

  @@map("channel_partner_onboarding_status")
}

enum ChannelPartnerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED

  @@map("channel_partner_status")
}

/// A broker / channel partner who sources leads for the business. In Indian real
/// estate 60-80% of bookings come through channel partners, so this tracks
/// onboarding, allocated leads, and commission terms in one place.
model ChannelPartner {
  id                  String                         @id @default(uuid())
  tenantId            String                         @map("tenant_id")
  tenant              Tenant                         @relation(fields: [tenantId], references: [id])
  name                String
  company             String?
  phone               String?
  email               String?
  reraId              String?
  reraExpiryAt        DateTime?
  agreementSignedAt   DateTime?
  agreementExpiryAt   DateTime?
  onboardingStatus    ChannelPartnerOnboardingStatus @default(INVITED)
  trainingCompletedAt DateTime?
  commissionRate      Float? // percent
  status              ChannelPartnerStatus           @default(ACTIVE)
  notes               String?
  metadata            Json                           @default("{}")
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  leads                  Lead[]
  portalUsers            PartnerPortalUser[]
  leadClaims             PartnerLeadClaim[]
  commissionPlans        CommissionPlan[]
  commissionAccruals     CommissionAccrual[]
  commissionPayouts      CommissionPayout[]
  marketingEventInvitees MarketingEventInvitee[]

  @@index([tenantId])
  @@index([status])
  @@map("channel_partners")
}

// === SHIPMENT / CONSIGNMENT (Logistics) ===

enum ShipmentType {
  FTL
  LTL
  AIR_FREIGHT
  SEA_FREIGHT
  EXPRESS
  COURIER

  @@map("shipment_type")
}

enum ShipmentStatus {
  QUOTE_REQUESTED
  QUOTE_SENT
  BOOKED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  EXCEPTION

  @@map("shipment_status")
}

enum CargoType {
  GENERAL
  PERISHABLE
  FRAGILE
  HAZARDOUS
  OVERSIZED
  VEHICLE
  ELECTRONICS

  @@map("cargo_type")
}

model Shipment {
  id                  String         @id @default(uuid())
  tenantId            String         @map("tenant_id")
  leadId              String
  title               String?
  origin              String
  destination         String
  cargoType           CargoType      @default(GENERAL)
  shipmentType        ShipmentType   @default(FTL)
  weight              Float?
  weightUnit          String         @default("kg")
  pickupDate          DateTime?
  deliveryDate        DateTime?
  scheduledPickupAt   DateTime?
  scheduledDeliveryAt DateTime?
  quotedPrice         Float?
  currency            String         @default("INR")
  finalPrice          Float?
  trackingNumber      String?
  vehicleType         String?
  carrierId           String?
  carrierName         String?
  notes               String?
  metadata            Json           @default("{}")
  status              ShipmentStatus @default(QUOTE_REQUESTED)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  lead          Lead                    @relation(fields: [leadId], references: [id])
  tenant        Tenant                  @relation(fields: [tenantId], references: [id])
  statusHistory ShipmentStatusHistory[]

  @@index([tenantId])
  @@index([leadId])
  @@index([status])
  @@index([trackingNumber])
  @@index([createdAt])
  @@map("shipments")
}

model ShipmentStatusHistory {
  id         String         @id @default(uuid())
  shipmentId String         @map("shipment_id")
  shipment   Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status     ShipmentStatus
  location   String?
  notes      String?
  createdAt  DateTime       @default(now())

  @@index([shipmentId])
  @@map("shipment_status_history")
}

model Integration {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  type       String
  name       String
