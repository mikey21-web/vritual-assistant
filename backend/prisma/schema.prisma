model Partner {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  type      String   @default("VENDOR") // VENDOR | SUPPLIER | BOTH
  company   String?
  email     String?
  phone     String?
  gstin     String?
  location  String?
  address   String?
  category  String?
  specialty String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendorAssignments EventVendorAssignment[]
  vendorBookings    VendorBooking[]
  purchaseOrders    PurchaseOrder[]

  @@index([tenantId])
  @@map("partners")
}

// === CLIENT FINANCE (invoices, quotations, contracts — distinct from platform subscription billing) ===

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  PENDING
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  CANCELLED
}

enum TransactionPartyType {
  CUSTOMER
  VENDOR
  INTERNAL
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  RECEIVED
  PAID
  PENDING
  OVERDUE
}

model Invoice {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id])
  eventId       String?
  invoiceNumber String        @unique
  subtotal      Float         @default(0)
  gstPercent    Float?
  gstTotal      Float         @default(0)
  grandTotal    Float         @default(0)
  status        InvoiceStatus @default(DRAFT)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lineItems InvoiceLineItem[]
  milestone PaymentMilestone?

  @@index([tenantId])
  @@index([contactId])
  @@index([eventId])
  @@index([status])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  description String
  qty         Float   @default(1)
  unitPrice   Float
  total       Float

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Quotation {
  id                      String          @id @default(uuid())
  tenantId                String          @map("tenant_id")
  contactId               String?
  contact                 Contact?        @relation(fields: [contactId], references: [id])
  eventId                 String?
  quoteNumber             String          @unique
  validUntil              DateTime?
  status                  QuotationStatus @default(DRAFT)
  notes                   String?
  termsAndPaymentSchedule String?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  sections  QuoteSection[]
  contracts Contract[]

  @@index([tenantId])
  @@index([contactId])
  @@index([eventId])
  @@index([status])
  @@map("quotations")
}

model QuoteSection {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  title       String
  order       Int       @default(0)

  lineItems QuoteLineItem[]

  @@index([quotationId])
  @@map("quote_sections")
}

model QuoteLineItem {
  id          String       @id @default(uuid())
  sectionId   String
  section     QuoteSection @relation(fields: [sectionId], references: [id])
  description String
  qty         Float        @default(1)
  unitPrice   Float
  total       Float

  @@index([sectionId])
  @@map("quote_line_items")
}

model Contract {
  id             String         @id @default(uuid())
  tenantId       String         @map("tenant_id")
  quotationId    String?
  quotation      Quotation?     @relation(fields: [quotationId], references: [id])
  contactId      String?
  contact        Contact?       @relation(fields: [contactId], references: [id])
  eventId        String?
  contractNumber String         @unique
  amount         Float          @default(0)
  status         ContractStatus @default(DRAFT)
  signedAt       DateTime?
  acceptedAt     DateTime?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([tenantId])
  @@index([quotationId])
  @@index([contactId])
  @@index([eventId])
  @@index([status])
  @@map("contracts")
}

model Transaction {
  id          String               @id @default(uuid())
  tenantId    String               @map("tenant_id")
  description String
  partyType   TransactionPartyType @default(INTERNAL)
  type        TransactionType
  amount      Float
  category    String?
  gstPercent  Float?
  date        DateTime             @default(now())
  status      TransactionStatus    @default(PENDING)
  invoiceRef  String?
  eventId     String?
  createdAt   DateTime             @default(now())

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([eventId])
  @@map("transactions")
}

// === PROCUREMENT ===

enum VendorBookingStatus {
  DRAFT
  SENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  PARTIAL
  RECEIVED
  CANCELLED
}

model VendorBooking {
  id                  String              @id @default(uuid())
  tenantId            String              @map("tenant_id")
  partnerId           String
  partner             Partner             @relation(fields: [partnerId], references: [id])
  eventId             String
  event               Event               @relation(fields: [eventId], references: [id])
  title               String
  eventDate           DateTime?
  vendorArrivalTime   DateTime?
  venue               String?
  deliverables        String[]            @default([])
  specialRequirements String?
  agreedFee           Float               @default(0)
  advanceAmount       Float               @default(0)
  balanceDueDate      DateTime?
  cancellationTerms   String?
  status              VendorBookingStatus @default(DRAFT)
  internalNotes       String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([tenantId])
  @@index([partnerId])
  @@index([eventId])
  @@index([status])
  @@map("vendor_bookings")
}

model PurchaseOrder {
  id               String              @id @default(uuid())
  tenantId         String              @map("tenant_id")
  partnerId        String
  partner          Partner             @relation(fields: [partnerId], references: [id])
  eventId          String?
  expectedDelivery DateTime?
  status           PurchaseOrderStatus @default(DRAFT)
  notes            String?
  totalValue       Float               @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  lineItems POLineItem[]

  @@index([tenantId])
  @@index([partnerId])
  @@index([eventId])
  @@index([status])
  @@map("purchase_orders")
}

model POLineItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  description     String
  qty             Float         @default(1)
  unitCost        Float
  total           Float

  @@index([purchaseOrderId])
  @@map("po_line_items")
}

// === INVENTORY ===

enum StockMovementType {
  RECEIVED
  SHIPPED
  TRANSFER
  ADJUSTMENT
}

model InventoryLocation {
  id               String              @id @default(uuid())
  tenantId         String              @map("tenant_id")
  name             String
  type             String              @default("Warehouse") // Warehouse | Zone | Vehicle | EventSite
  description      String?
  active           Boolean             @default(true)
  parentLocationId String?
  parentLocation   InventoryLocation?  @relation("LocationHierarchy", fields: [parentLocationId], references: [id])
  childLocations   InventoryLocation[] @relation("LocationHierarchy")
  createdAt        DateTime            @default(now())

  itemsAtLocation InventoryItem[] @relation("ItemLocation")
  movementsFrom   StockMovement[] @relation("MovementFrom")
  movementsTo     StockMovement[] @relation("MovementTo")

  @@index([tenantId])
  @@map("inventory_locations")
}

model InventoryItem {
  id                  String             @id @default(uuid())
  tenantId            String             @map("tenant_id")
  name                String
  category            String?
  sku                 String?
  size                String?
  quantity            Float              @default(0)
  minStock            Float              @default(0)
  unit                String?
  locationId          String?
  location            InventoryLocation? @relation("ItemLocation", fields: [locationId], references: [id])
  barcode             String?
  supplierInfo        String?
  purchaseHistory     String?
  deploymentCondition String?
  photoUrl            String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  movements   StockMovement[]
  allocations InventoryAllocation[]

  @@index([tenantId])
  @@index([locationId])
  @@map("inventory_items")
}

model StockMovement {
  id             String             @id @default(uuid())
  tenantId       String             @map("tenant_id")
  itemId         String
  item           InventoryItem      @relation(fields: [itemId], references: [id])
  type           StockMovementType
  qty            Float
  fromLocationId String?
  fromLocation   InventoryLocation? @relation("MovementFrom", fields: [fromLocationId], references: [id])
  toLocationId   String?
  toLocation     InventoryLocation? @relation("MovementTo", fields: [toLocationId], references: [id])
  refNotes       String?
  date           DateTime           @default(now())

  @@index([tenantId])
  @@index([itemId])
  @@map("stock_movements")
}

// === TEAM / HR ===

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollEntryType {
  SALARY
  ADVANCE
}

model LeaveRequest {
  id           String             @id @default(uuid())
  tenantId     String             @map("tenant_id")
  userId       String
  user         User               @relation("LeaveRequestUser", fields: [userId], references: [id])
  startDate    DateTime
  endDate      DateTime
  status       LeaveRequestStatus @default(PENDING)
  approvedById String?
  approvedBy   User?              @relation("LeaveRequestApprover", fields: [approvedById], references: [id])
  createdAt    DateTime           @default(now())

  @@index([tenantId])
  @@index([userId])
  @@map("leave_requests")
}

model SalaryRecord {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  month     String
  amount    Float
  type      PayrollEntryType @default(SALARY)
  paidAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([tenantId])
  @@index([userId])
  @@map("salary_records")
}

model TimesheetEntry {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  role      String?
  date      DateTime
  hours     Float
  overtime  Float    @default(0)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([eventId])
  @@map("timesheet_entries")
}

// === PERMISSIONS MATRIX ===

enum PermissionModule {
  DASHBOARD
  EVENTS
  CRM
  VENDORS
  TEAM
  TIMESHEET
  ACCOUNTING
  INVENTORY
  PROCUREMENT
}

enum PermissionLevel {
  NO_ACCESS
  VIEW_ONLY
  EDIT
  FULL_ACCESS
}

model ModulePermission {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  userId    String
  user      User             @relation("ModulePermissionUser", fields: [userId], references: [id])
  module    PermissionModule
  level     PermissionLevel  @default(NO_ACCESS)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, module])
  @@index([tenantId])
  @@map("module_permissions")
}

/// A pending invitation to join the workspace. Unlike the old admin-sets-
/// the-password flow (POST /users), the invitee sets their own password via
/// a tokenized link, and their module permissions are captured here at
/// invite time so they're applied the moment the account is actually created.
model TeamInvite {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  name         String
  email        String
  role         String    @default("SALES_AGENT")
  department   String?
  moduleGrants Json      @default("{}")
  token        String    @unique
  status       String    @default("PENDING") // PENDING | ACCEPTED | REVOKED | EXPIRED
  invitedById  String?
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([email])
  @@map("team_invites")
}

// === PUBLIC BUSINESS PROFILE (microsite) ===

model PublicProfile {
  id              String   @id @default(uuid())
  tenantId        String   @unique @map("tenant_id")
  companyName     String?
  slug            String?  @unique
  tagline         String?
  city            String?
  address         String?
  yearsExperience Int?
  eventsExecuted  Int?
  about           String?
  phone           String?
  whatsapp        String?
  email           String?
  website         String?
  instagramUrl    String?
  youtubeUrl      String?
  facebookUrl     String?
  googleMapsUrl   String?
  servicesOffered String[] @default([])
  coverImageUrl   String?
  published       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("public_profiles")
}

model InventoryAllocation {
  id           String        @id @default(uuid())
  tenantId     String        @map("tenant_id")
  eventId      String
  event        Event         @relation(fields: [eventId], references: [id])
  itemId       String
  item         InventoryItem @relation(fields: [itemId], references: [id])
  qtyAllocated Float
  createdAt    DateTime      @default(now())

  @@index([tenantId])
  @@index([eventId])
  @@index([itemId])
  @@map("inventory_allocations")
}

// === PEAK MIKEY — P5 FEDERATED AGGREGATOR ===

model FederatedOptIn {
  id        String   @id @default(uuid())
  tenantId  String   @unique @map("tenant_id")
  optedIn   Boolean  @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("federated_opt_ins")
}

model FederatedAggregate {
  id         String    @id @default(uuid())
  niche      String
  tenantId   String    @map("tenant_id")
  metric     String
  value      Float
  noise      Float
  sampleSize Int
  reportedAt DateTime  @default(now())
  expiresAt  DateTime?

  @@index([niche, metric])
  @@index([reportedAt])
  @@map("federated_aggregates")
}

// === PEAK MIKEY — P3 REAL MEMORY SYSTEM ===

enum MemoryType {
  WORKING
  EPISODIC
  SEMANTIC
  PROCEDURAL
}

model MikeyMemory {
  id           String     @id @default(uuid())
  tenantId     String     @map("tenant_id")
  type         MemoryType
  key          String
  value        String
  summary      String?
  source       String? // "lead_voice" | "operator_voice" | "scheduler" | "reflexion"
  leadId       String?
  episodeStart DateTime?
  episodeEnd   DateTime?
  validAt      DateTime   @default(now())
  invalidAt    DateTime?
  confidence   Float      @default(0.5)
  embedding    Float[]    @default([]) // pgvector embedding
  metadata     Json       @default("{}")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenantId, type])
  @@index([tenantId, key])
  @@index([tenantId, type, leadId])
  @@index([validAt])
  @@map("mikey_memory")
}

model MikeyProceduralRule {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  rule           String
  rationale      String?
  category       String? // "follow_up" | "pricing" | "routing" | "messaging" | "general"
  impactMetric   String? // "conversion_rate" | "response_time" | "booking_rate"
  impactDelta    Float? // measured % change after rule was applied
  status         String    @default("pending") // pending | approved | active | retired
  approvedAt     DateTime?
  approvedById   String?
  firstAppliedAt DateTime?
  lastAppliedAt  DateTime?
  retireAt       DateTime?
  applyCount     Int       @default(0)
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, category])
  @@map("mikey_procedural_rules")
}

model MikeyReflexionLog {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  outcomeType    String // "lead_converted" | "lead_lost" | "campaign_result" | "booking_outcome"
  entityId       String?
  trajectory     Json // sequence of actions taken
  reflection     String // natural-language post-mortem
  candidateRule  String? // extracted procedural rule suggestion
  perspectives   Json? // multi-perspective reflections (skeptic + optimizer)
  approvedRuleId String?
  createdAt      DateTime @default(now())

  @@index([tenantId, outcomeType])
  @@map("mikey_reflexion_logs")
}

/// A record of every action Mikey took on its own, without being asked —
/// the audit trail + undo primitive that makes autonomy safe to expand.
/// findingType links back to the MikeySchedulerService detection that
/// triggered it (e.g. "stale_hot_leads", "unassigned_hot_leads").
model MikeyAutonomousAction {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  findingType String
  tool        String
  leadId      String?
  args        Json      @default("{}")
  result      String?
  undoable    Boolean   @default(false)
  undoData    Json? // prior-state snapshot needed to reverse the action
  undone      Boolean   @default(false)
  undoneAt    DateTime?
  undoneById  String?
  createdAt   DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, undone])
  @@map("mikey_autonomous_actions")
}

// === KYC / DOCUMENTS ===
// Never store raw Aadhaar numbers, document passwords, or bank secrets here —
// only masked identifiers, verification status, consent, and a provider
// response reference (spec 48.10 / 55.4 invariant 7: an unverified document
// is never displayed as verified).

enum BuyerDocumentType {
  PAN
  AADHAAR_OFFLINE_XML
  ADDRESS_PROOF
  PHOTO
  SALARY_PROOF
  BANK_STATEMENT
  LOAN_SANCTION_LETTER
  BOOKING_FORM
  ALLOTMENT_LETTER
  AGREEMENT_DRAFT
  SIGNED_AGREEMENT
  NOC
  POSSESSION_LETTER
  OTHER

  @@map("buyer_document_type")
}

enum BuyerDocumentStatus {
  NOT_REQUESTED
  REQUESTED
  UPLOADED
  PROCESSING
  VERIFIED
  REJECTED
  EXPIRED
  WAIVED

  @@map("buyer_document_status")
}

model BuyerDocument {
  id                   String              @id @default(uuid())
  tenantId             String              @map("tenant_id")
  tenant               Tenant              @relation(fields: [tenantId], references: [id])
  leadId               String
  lead                 Lead                @relation(fields: [leadId], references: [id])
  bookingId            String?
  booking              Booking?            @relation(fields: [bookingId], references: [id])
  type                 BuyerDocumentType
  status               BuyerDocumentStatus @default(NOT_REQUESTED)
  mediaFileId          String?
  mediaFile            MediaFile?          @relation(fields: [mediaFileId], references: [id])
  documentNumberMasked String?
  source               String? // buyer_upload | staff_upload | digilocker
  issuedAt             DateTime?
  expiresAt            DateTime?
  requestedById        String?
  requestedBy          User?               @relation("BuyerDocumentRequestedBy", fields: [requestedById], references: [id])
  verifiedById         String?
  verifiedBy           User?               @relation("BuyerDocumentVerifiedBy", fields: [verifiedById], references: [id])
  verifiedAt           DateTime?
  rejectionReason      String?
  metadata             Json                @default("{}")
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  verifications KycVerification[]

  @@index([tenantId, status])
  @@index([leadId])
  @@index([bookingId])
  @@map("buyer_documents")
}

enum KycVerificationType {
  MANUAL
  AADHAAR_OFFLINE_EKYC
  DIGILOCKER

  @@map("kyc_verification_type")
}

enum KycVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED

  @@map("kyc_verification_status")
}

/// A single consented verification event against a BuyerDocument. Holds only
/// the verification outcome and a provider reference — never the underlying
/// XML/ZIP/share code, which per spec 48.10 must be discarded immediately
/// after a short-lived worker validates it.
model KycVerification {
  id                  String                @id @default(uuid())
  tenantId            String                @map("tenant_id")
  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  buyerDocumentId     String
  buyerDocument       BuyerDocument         @relation(fields: [buyerDocumentId], references: [id], onDelete: Cascade)
  leadId              String
  lead                Lead                  @relation(fields: [leadId], references: [id])
  type                KycVerificationType
  status              KycVerificationStatus @default(PENDING)
  providerResponseRef String?
  consentAt           DateTime?
  consentIp           String?
  verifiedById        String?
  verifiedBy          User?                 @relation(fields: [verifiedById], references: [id])
  verifiedAt          DateTime?
  metadata            Json                  @default("{}")
  createdAt           DateTime              @default(now())

  @@index([tenantId, status])
  @@index([buyerDocumentId])
  @@index([leadId])
  @@map("kyc_verifications")
}

enum DocumentTemplateStatus {
  DRAFT
  APPROVED
  RETIRED

  @@map("document_template_status")
}

/// A legal/finance-approved template for a generated document (agreement,
/// demand letter, NOC, ...). Generation always snapshots the template
/// version used so an issued document never silently changes (spec 69.1).
model DocumentTemplate {
  id           String                 @id @default(uuid())
  tenantId     String                 @map("tenant_id")
  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  name         String
  documentType String
  version      Int                    @default(1)
  status       DocumentTemplateStatus @default(DRAFT)
  bodyTemplate String
  variables    Json                   @default("[]")
  approvedById String?
  approvedBy   User?                  @relation(fields: [approvedById], references: [id])
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  generatedDocuments GeneratedDocument[]

  @@index([tenantId, documentType, status])
  @@map("document_templates")
}

model GeneratedDocument {
  id            String           @id @default(uuid())
  tenantId      String           @map("tenant_id")
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  templateId    String
  template      DocumentTemplate @relation(fields: [templateId], references: [id])
  leadId        String
  lead          Lead             @relation(fields: [leadId], references: [id])
  bookingId     String?
  booking       Booking?         @relation(fields: [bookingId], references: [id])
  generatedById String?
  generatedBy   User?            @relation(fields: [generatedById], references: [id])
  snapshot      Json             @default("{}")
  mediaFileId   String?
  mediaFile     MediaFile?       @relation(fields: [mediaFileId], references: [id])
  createdAt     DateTime         @default(now())

  esignRequests ESignRequest[]

  @@index([tenantId])
  @@index([leadId])
  @@index([bookingId])
  @@map("generated_documents")
}

enum ESignStatus {
  CREATED
  SENT
  SIGNED
  EXPIRED
  REJECTED

  @@map("esign_status")
}

model ESignRequest {
  id                  String            @id @default(uuid())
  tenantId            String            @map("tenant_id")
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  generatedDocumentId String
  generatedDocument   GeneratedDocument @relation(fields: [generatedDocumentId], references: [id])
  provider            String
  envelopeId          String?
  status              ESignStatus       @default(CREATED)
  signerName          String?
  signerEmail         String?
  signerPhone         String?
  sentAt              DateTime?
  completedAt         DateTime?
  metadata            Json              @default("{}")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([tenantId, status])
  @@index([generatedDocumentId])
  @@map("esign_requests")
}

// === COLLECTIONS: RECEIPTS + LEDGER ===

enum PaymentReceiptStatus {
  PENDING_RECONCILIATION
  CONFIRMED
  REVERSED
  FAILED

  @@map("payment_receipt_status")
}

/// A recorded payment against one or more PaymentSchedule milestones. Never
/// mutated after CONFIRMED — a correction creates a REVERSED status plus a
/// new LedgerEntry, preserving a full audit trail (spec 48.11).
model PaymentReceipt {
  id                String               @id @default(uuid())
  tenantId          String               @map("tenant_id")
  tenant            Tenant               @relation(fields: [tenantId], references: [id])
  leadId            String
  lead              Lead                 @relation(fields: [leadId], references: [id])
  bookingId         String?
  booking           Booking?             @relation(fields: [bookingId], references: [id])
  externalRef       String? // UTR / cheque / DD / gateway reference
  amountPaise       BigInt
  mode              String // UPI | NEFT | CHEQUE | CARD | CASH | GATEWAY
  receivedAt        DateTime             @default(now())
  status            PaymentReceiptStatus @default(PENDING_RECONCILIATION)
  attachmentMediaId String?
  attachmentMedia   MediaFile?           @relation(fields: [attachmentMediaId], references: [id])
  confirmedById     String?
  confirmedBy       User?                @relation("PaymentReceiptConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt       DateTime?
  reversedAt        DateTime?
  reversalReason    String?
  metadata          Json                 @default("{}")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  allocations   PaymentAllocation[]
  ledgerEntries LedgerEntry[]

  @@index([tenantId, status])
  @@index([leadId])
  @@index([bookingId])
  @@map("payment_receipts")
}

/// One payment can allocate across multiple milestones (spec 48.11) — this is
/// the join between a receipt and the PaymentSchedule rows it settles.
model PaymentAllocation {
  id                String          @id @default(uuid())
  paymentReceiptId  String
  paymentReceipt    PaymentReceipt  @relation(fields: [paymentReceiptId], references: [id], onDelete: Cascade)
  paymentScheduleId String
  paymentSchedule   PaymentSchedule @relation(fields: [paymentScheduleId], references: [id])
  amountPaise       BigInt
  createdAt         DateTime        @default(now())

  @@index([paymentReceiptId])
  @@index([paymentScheduleId])
  @@map("payment_allocations")
}

enum LedgerEntryType {
  DEBIT
  CREDIT
  PAYMENT
  WAIVER
  REVERSAL
  REFUND

  @@map("ledger_entry_type")
}

/// Append-only buyer ledger (spec 48.11) — current balance is always computed
/// from these rows, never hand-typed. Nothing here is ever updated in place.
model LedgerEntry {
  id               String          @id @default(uuid())
  tenantId         String          @map("tenant_id")
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  leadId           String
  lead             Lead            @relation(fields: [leadId], references: [id])
  bookingId        String?
  booking          Booking?        @relation(fields: [bookingId], references: [id])
  type             LedgerEntryType
  amountPaise      BigInt
  relatedReceiptId String?
  relatedReceipt   PaymentReceipt? @relation(fields: [relatedReceiptId], references: [id])
  description      String?
  createdById      String?
  createdBy        User?           @relation(fields: [createdById], references: [id])
  createdAt        DateTime        @default(now())

  @@index([tenantId, leadId])
  @@index([bookingId])
  @@map("ledger_entries")
}

// === CHANNEL PARTNER PORTAL ===

/// Separate auth/session scope from the internal User table (spec 48.12) — a
/// partner logging in must never inherit internal tenant-staff permissions.
model PartnerPortalUser {
  id               String         @id @default(uuid())
  tenantId         String         @map("tenant_id")
  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  channelPartnerId String
  channelPartner   ChannelPartner @relation(fields: [channelPartnerId], references: [id])
  email            String         @unique
  passwordHash     String
  active           Boolean        @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([tenantId, channelPartnerId])
  @@map("partner_portal_users")
}

enum PartnerLeadClaimStatus {
  REGISTERED
  ALREADY_REGISTERED
  NEEDS_REVIEW
  REJECTED

  @@map("partner_lead_claim_status")
}

/// A partner's lead registration attempt. The response to the partner must
/// stay neutral (spec 48.12) — never leak another partner's name — while an
/// internal manager resolves disputes with an immutable decision record.
model PartnerLeadClaim {
  id               String                 @id @default(uuid())
  tenantId         String                 @map("tenant_id")
  tenant           Tenant                 @relation(fields: [tenantId], references: [id])
  channelPartnerId String
  channelPartner   ChannelPartner         @relation(fields: [channelPartnerId], references: [id])
  leadId           String?
  lead             Lead?                  @relation(fields: [leadId], references: [id])
  phone            String
  status           PartnerLeadClaimStatus @default(REGISTERED)
  lockUntil        DateTime?
  decidedById      String?
  decidedBy        User?                  @relation(fields: [decidedById], references: [id])
  decidedAt        DateTime?
  decisionReason   String?
  createdAt        DateTime               @default(now())

  @@index([tenantId, channelPartnerId])
  @@index([phone])
  @@index([leadId])
  @@map("partner_lead_claims")
}

/// A versioned commission rule. Every accrual snapshots the plan that
/// produced it (spec 48.12 / 70.2) so a later plan change never rewrites
/// history.
model CommissionPlan {
  id               String          @id @default(uuid())
  tenantId         String          @map("tenant_id")
  tenant           Tenant          @relation(fields: [tenantId], references: [id])
  channelPartnerId String?
  channelPartner   ChannelPartner? @relation(fields: [channelPartnerId], references: [id])
  name             String
  triggerEvent     String // BOOKING | COLLECTION
  rateType         String // FLAT | PERCENT
  ratePaise        BigInt?
  ratePercent      Float?
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  accruals CommissionAccrual[]

  @@index([tenantId, channelPartnerId, active])
  @@map("commission_plans")
}

enum CommissionAccrualStatus {
  PENDING
  APPROVED
  PAID
  CLAWED_BACK

  @@map("commission_accrual_status")
}

model CommissionAccrual {
  id               String                  @id @default(uuid())
  tenantId         String                  @map("tenant_id")
  tenant           Tenant                  @relation(fields: [tenantId], references: [id])
  channelPartnerId String
  channelPartner   ChannelPartner          @relation(fields: [channelPartnerId], references: [id])
  bookingId        String?
  booking          Booking?                @relation(fields: [bookingId], references: [id])
  planId           String?
  plan             CommissionPlan?         @relation(fields: [planId], references: [id])
  amountPaise      BigInt
  status           CommissionAccrualStatus @default(PENDING)
  policySnapshot   Json                    @default("{}")
  payoutId         String?
  payout           CommissionPayout?       @relation(fields: [payoutId], references: [id])
  approvedById     String?
  approvedBy       User?                   @relation(fields: [approvedById], references: [id])
  approvedAt       DateTime?
  createdAt        DateTime                @default(now())

  @@index([tenantId, channelPartnerId, status])
  @@index([bookingId])
  @@index([payoutId])
  @@map("commission_accruals")
}

model CommissionPayout {
  id               String         @id @default(uuid())
  tenantId         String         @map("tenant_id")
  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  channelPartnerId String
  channelPartner   ChannelPartner @relation(fields: [channelPartnerId], references: [id])
  amountPaise      BigInt
  reference        String?
  paidAt           DateTime?
  approvedById     String?
  approvedBy       User?          @relation(fields: [approvedById], references: [id])
  createdAt        DateTime       @default(now())

  accruals CommissionAccrual[]

  @@index([tenantId, channelPartnerId])
  @@map("commission_payouts")
}

// === CROSS-CUTTING: INTEGRATION EVENTS, SLA BREACHES, APPROVAL REQUESTS ===

enum IntegrationEventStatus {
  RECEIVED
  PROCESSED
  FAILED

  @@map("integration_event_status")
}

/// First-class idempotency store for external webhooks (spec 46.2 / 49.2): a
/// provider event ID is recorded here before any side effect runs, so a
/// retried webhook can never create a duplicate lead/message/booking/payment.
model IntegrationEvent {
  id          String                 @id @default(uuid())
  tenantId    String?                @map("tenant_id")
  tenant      Tenant?                @relation(fields: [tenantId], references: [id])
  provider    String
  eventId     String
  status      IntegrationEventStatus @default(RECEIVED)
  payload     Json                   @default("{}")
  error       String?
  processedAt DateTime?
  createdAt   DateTime               @default(now())

  @@unique([provider, eventId])
  @@index([tenantId, status])
  @@map("integration_events")
}

/// First-class SLA breach record (spec 46.2 / 6): a scan writes one row per
/// missed target so "8 hot leads are untouched" is a real, queryable, auditable
/// fact instead of a transient in-memory finding.
model SlaBreach {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  slaRuleId     String?
  slaRule       SlaRule?  @relation(fields: [slaRuleId], references: [id])
  leadId        String?
  lead          Lead?     @relation(fields: [leadId], references: [id])
  entityType    String
  entityId      String
  breachType    String
  detectedAt    DateTime  @default(now())
  resolvedAt    DateTime?
  escalatedToId String?
  escalatedTo   User?     @relation(fields: [escalatedToId], references: [id])
  metadata      Json      @default("{}")

  @@index([tenantId, resolvedAt])
  @@index([leadId])
  @@map("sla_breaches")
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED

  @@map("approval_request_status")
}

/// Generic approval object shared by discount/hold-extension/booking-cancel/
/// price-override/payment-waiver flows (spec 46.5) instead of one-off ad hoc
/// approval fields scattered per module.
model ApprovalRequest {
  id             String                @id @default(uuid())
  tenantId       String                @map("tenant_id")
  tenant         Tenant                @relation(fields: [tenantId], references: [id])
  type           String
  entityType     String
  entityId       String
  requestedById  String?
  requestedBy    User?                 @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  status         ApprovalRequestStatus @default(PENDING)
  policySnapshot Json                  @default("{}")
  amountPaise    BigInt?
  reason         String?
  approvedById   String?
  approvedBy     User?                 @relation("ApprovalDecidedBy", fields: [approvedById], references: [id])
  decidedAt      DateTime?
  expiresAt      DateTime?
  createdAt      DateTime              @default(now())

  @@index([tenantId, status])
  @@index([entityType, entityId])
  @@map("approval_requests")
}

/// Configurable approval matrix: which role must decide a given approval `type`
/// once its amount crosses `minAmountPaise`. Matched by highest minAmountPaise
/// <= the request's amount; falls back to MANAGER when no policy matches.
model ApprovalPolicy {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  type           String
  minAmountPaise BigInt?
  requiredRole   UserRole
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, type])
  @@map("approval_policies")
}

// === BUYER PORTAL ===

/// Single-purpose, hashed, short-lived magic link for buyer portal login
/// (spec 54.1). Never store the raw token — only its hash — and a token can
/// only ever be used once.
model BuyerPortalToken {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  bookingId String
  booking   Booking   @relation(fields: [bookingId], references: [id])
  contactId String?
  contact   Contact?  @relation(fields: [contactId], references: [id])
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId, bookingId])
  @@map("buyer_portal_tokens")
}

// === PAYMENT PLAN TEMPLATES ===

enum PaymentPlanType {
  CONSTRUCTION_LINKED
  TIME_LINKED
  DOWN_PAYMENT
  SUBVENTION
  CUSTOM

  @@map("payment_plan_type")
}

/// A reusable milestone breakdown (spec 16/54.5) — `milestones` is an ordered
/// JSON array of `{ label, percentage, dueOffsetDays?, triggerNote? }`.
/// dueOffsetDays anchors a milestone to the booking date (time-linked plans);
/// construction-linked milestones instead carry a triggerNote and get their
/// due date set manually once that construction stage is actually reached —
/// this app has no way to know real-world construction progress on its own.
model PaymentPlanTemplate {
  id         String          @id @default(uuid())
  tenantId   String          @map("tenant_id")
  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  name       String
  planType   PaymentPlanType
  milestones Json            @default("[]")
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([tenantId, planType, active])
  @@map("payment_plan_templates")
}

// === MODULE 4.1: MARKETING JOURNEY BUILDER ===

enum JourneyStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED

  @@map("journey_status")
}

enum JourneyStepType {
  WAIT
  SEND_TEMPLATE
  CREATE_TASK
  WEBHOOK
  EXIT_CONDITION

  @@map("journey_step_type")
}

enum JourneyEnrollmentStatus {
  ACTIVE
  COMPLETED
  EXITED

  @@map("journey_enrollment_status")
}

/// A configurable multi-step drip campaign (nurture sequence) for automating
/// lead follow-up over time. Separate from the simpler Campaign model because
/// this one encodes ordered steps with conditions, version snapshots, and
/// per-lead enrollment progress — a full automation journey, not a one-off send.
model MarketingJourney {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  name            String
  status          JourneyStatus @default(DRAFT)
  entryEventType  String // e.g. "lead.created", "site_visit.no_show"
  entryConditions Json          @default("{}")
  version         Int           @default(1)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  steps       MarketingJourneyStep[]
  enrollments MarketingJourneyEnrollment[]

  @@index([tenantId, status])
  @@map("marketing_journeys")
}

/// An ordered step within a MarketingJourney. The step's config JSON holds
/// step-type-specific fields (e.g. waitHours for WAIT, templateId for SEND_TEMPLATE).
model MarketingJourneyStep {
  id        String           @id @default(uuid())
  journeyId String
  journey   MarketingJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  order     Int
  stepType  JourneyStepType
  config    Json             @default("{}")
  createdAt DateTime         @default(now())

  @@index([journeyId])
  @@map("marketing_journey_steps")
}

/// A lead enrolled in a MarketingJourney. Snapshots the journey version/steps
/// at enrollment time so retroactive changes never alter an enrolled lead's path.
model MarketingJourneyEnrollment {
  id               String                  @id @default(uuid())
  tenantId         String                  @map("tenant_id")
  tenant           Tenant                  @relation(fields: [tenantId], references: [id])
  journeyId        String
  journey          MarketingJourney        @relation(fields: [journeyId], references: [id])
  leadId           String
  lead             Lead                    @relation(fields: [leadId], references: [id])
  currentStepOrder Int                     @default(0)
  status           JourneyEnrollmentStatus @default(ACTIVE)
  journeySnapshot  Json                    @default("{}") // snapshot of steps at enrollment time
  enrolledAt       DateTime                @default(now())
  completedAt      DateTime?

  @@unique([journeyId, leadId])
  @@index([tenantId, status])
  @@map("marketing_journey_enrollments")
}

// === MODULE 4.2: EVENTS / LAUNCHES ===

enum MarketingEventType {
  OPEN_HOUSE
  BROKER_MEET
  LAUNCH
  WEBINAR
  SITE_VISIT_DRIVE

  @@map("marketing_event_type")
}

enum MarketingEventStatus {
  DRAFT
  PUBLISHED
  COMPLETED
  CANCELLED

  @@map("marketing_event_status")
}

enum RsvpStatus {
  INVITED
  CONFIRMED
  DECLINED
  ATTENDED
  NO_SHOW

  @@map("rsvp_status")
}

/// A marketing/broker event (open house, project launch, broker meet, webinar)
/// with RSVP tracking and QR check-in. Separate from the existing Event model
/// (events_ops table) which is for internal event operations/management.
model MarketingEvent {
  id          String               @id @default(uuid())
  tenantId    String               @map("tenant_id")
  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  projectId   String?
  project     Project?             @relation(fields: [projectId], references: [id])
  name        String
  eventType   MarketingEventType
  startAt     DateTime
  endAt       DateTime?
  location    String?
  description String?
  capacity    Int?
  status      MarketingEventStatus @default(DRAFT)
  createdById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  invitees MarketingEventInvitee[]

  @@index([tenantId, status])
  @@index([projectId])
  @@map("marketing_events")
}

/// An invitee (lead or channel partner) to a marketing event, tracking RSVP
/// and QR-based check-in. qrCheckInToken is a short random string for
/// unauthenticated check-in at the venue.
model MarketingEventInvitee {
  id               String          @id @default(uuid())
  eventId          String
  event            MarketingEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  leadId           String?
  lead             Lead?           @relation(fields: [leadId], references: [id])
  channelPartnerId String?
  channelPartner   ChannelPartner? @relation(fields: [channelPartnerId], references: [id])
  name             String?
  phone            String?
  email            String?
  rsvpStatus       RsvpStatus      @default(INVITED)
  qrCheckInToken   String?         @unique
  checkedInAt      DateTime?
  createdAt        DateTime        @default(now())

  @@index([eventId])
  @@index([leadId])
  @@index([channelPartnerId])
  @@map("marketing_event_invitees")
}

// === MODULE 4.4: PROJECT CASH-FLOW FORECASTING ===

enum CashFlowEntryType {
  EXPECTED_COLLECTION
  EXPECTED_COMMISSION_PAYOUT
  EXPECTED_REFUND
  PLANNED_EXPENSE

  @@map("cash_flow_entry_type")
}

/// A single forecast entry for a project's projected cash position. Entries
/// can be auto-derived (from PaymentSchedule, CommissionAccrual) or manually
/// entered for planned expenses. Label clearly as forecast, not accounting.
model CashFlowForecastEntry {
  id           String            @id @default(uuid())
  tenantId     String            @map("tenant_id")
  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  projectId    String
  project      Project           @relation(fields: [projectId], references: [id])
  entryType    CashFlowEntryType
  amountPaise  BigInt
  expectedDate DateTime
  sourceType   String // e.g. "PaymentSchedule", "CommissionAccrual", "manual"
  sourceId     String? // id of originating record if auto-derived
  notes        String?
  createdById  String?
  createdAt    DateTime          @default(now())

  @@index([tenantId, projectId])
  @@index([projectId, expectedDate])
  @@map("cash_flow_forecast_entries")
}

// === MODULE 4.5: LANDOWNER / CO-PROMOTER REVENUE-SHARE ALLOCATION ===

enum RevenueSharePartyType {
  LANDOWNER
  CO_PROMOTER

  @@map("revenue_share_party_type")
}

enum RevenueShareAllocationStatus {
  PENDING
  CONFIRMED
  SETTLED

  @@map("revenue_share_allocation_status")
}

/// A landowner or co-promoter entitled to a share of booking revenue from a
/// project. Separate from ChannelPartner commissions since these are ownership
/// entitlements, not referral fees.
model RevenueShareParty {
  id           String                @id @default(uuid())
  tenantId     String                @map("tenant_id")
  tenant       Tenant                @relation(fields: [tenantId], references: [id])
  projectId    String
  project      Project               @relation(fields: [projectId], references: [id])
  partyName    String
  partyType    RevenueSharePartyType
  sharePercent Float // 0-100
  contactEmail String?
  contactPhone String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  allocations RevenueShareAllocation[]

  @@index([tenantId, projectId])
  @@map("revenue_share_parties")
}

/// An allocation of revenue (unit or booking-based) to a RevenueShareParty.
/// At least one of unitId/bookingId must be set.
model RevenueShareAllocation {
  id                   String                       @id @default(uuid())
  tenantId             String                       @map("tenant_id")
  tenant               Tenant                       @relation(fields: [tenantId], references: [id])
  partyId              String
  party                RevenueShareParty            @relation(fields: [partyId], references: [id])
  unitId               String?
  unit                 Unit?                        @relation(fields: [unitId], references: [id])
  bookingId            String?
  booking              Booking?                     @relation(fields: [bookingId], references: [id])
  allocatedAmountPaise BigInt?
  status               RevenueShareAllocationStatus @default(PENDING)
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  @@index([tenantId, partyId])
  @@index([unitId])
  @@index([bookingId])
  @@map("revenue_share_allocations")
}

// === MODULE 4.6: RESALE / RENTAL LISTING INVENTORY ===

enum ResaleListingType {
  RESALE
  RENTAL

  @@map("resale_listing_type")
}

enum ResaleListingStatus {
  AVAILABLE
  UNDER_NEGOTIATION
  CLOSED

  @@map("resale_listing_status")
}

/// Secondary-market resale and rental listings handled by the builder/broker.
/// Separate from new-developer Unit inventory (the builder's own project units)
/// and from Property (which is a generic broker listing — this one is explicitly
/// for resale/rental secondary market with its own lifecycle).
model ResaleListing {
  id                String              @id @default(uuid())
  tenantId          String              @map("tenant_id")
  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  listingType       ResaleListingType
  unitId            String?
  unit              Unit?               @relation(fields: [unitId], references: [id])
  externalOwnerName String? // seller/landlord name if not a tracked buyer
  askingPriceRupees Float? // kept as Float to match Property.price convention
  rentAmountRupees  Float? // for rentals
  location          String?
  bedrooms          Int?
  areaSqft          Float?
  status            ResaleListingStatus @default(AVAILABLE)
  images            Json                @default("[]")
  createdById       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([tenantId, status, listingType])
  @@index([location])
  @@map("resale_listings")
}

// === MODULE 4.7: REFERRAL / LOYALTY PROGRAM ===

enum ReferralRewardType {
  FLAT
  PERCENT_OF_BOOKING

  @@map("referral_reward_type")
}

enum ReferralStatus {
  SUBMITTED
  LEAD_CREATED
  BOOKED
  REWARD_APPROVED
  REWARD_PAID
  REJECTED

  @@map("referral_status")
}

/// A referral program configuration that existing buyers can use to refer new
/// leads. Rewards are never auto-paid — approval is always required.
model ReferralProgram {
  id                String             @id @default(uuid())
  tenantId          String             @map("tenant_id")
  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  name              String
  rewardType        ReferralRewardType
  rewardAmountPaise BigInt?
  rewardPercent     Float?
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  referrals Referral[]

  @@index([tenantId, active])
  @@map("referral_programs")
}

/// An individual referral submitted by an existing buyer (referrer) pointing to
/// a new prospect (referredPhone). Status tracks the referral from submission
/// through reward lifecycle. Self-referral and duplicate-referrer are blocked.
model Referral {
  id                String          @id @default(uuid())
  tenantId          String          @map("tenant_id")
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  programId         String
  program           ReferralProgram @relation(fields: [programId], references: [id])
  referrerContactId String
  referrerContact   Contact         @relation("ReferrerContact", fields: [referrerContactId], references: [id])
  referredLeadId    String?
  referredLead      Lead?           @relation("ReferredLead", fields: [referredLeadId], references: [id])
  referredPhone     String
  status            ReferralStatus  @default(SUBMITTED)
  rewardAmountPaise BigInt?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([tenantId, status])
  @@index([referrerContactId])
  @@index([referredLeadId])
  @@index([referredPhone])
  @@map("referrals")
}

// === MODULE 4.8: NRI / INTERNATIONAL BUYER WORKFLOW ===

/// Overseas buyer profile attached to a Lead. Adds timezone-aware scheduling
/// and document-type hints. One profile per lead (unique constraint on leadId).
model NriBuyerProfile {
  id                         String   @id @default(uuid())
  tenantId                   String   @map("tenant_id")
  tenant                     Tenant   @relation(fields: [tenantId], references: [id])
  leadId                     String   @unique
  lead                       Lead     @relation(fields: [leadId], references: [id])
  countryOfResidence         String
  timezone                   String // e.g. "America/New_York"
  preferredContactHoursLocal String? // e.g. "18:00-21:00"
  passportNumberMasked       String?
  overseasAddress            Json?    @default("{}")
  remotePaymentMethodNote    String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([tenantId])
  @@map("nri_buyer_profiles")
}

// === MODULE 4.9: VENDOR / CONSTRUCTION ERP INTEGRATION (STUB ADAPTER) ===

/// A per-project ERP connection configuration. Status defaults to NOT_CONFIGURED
/// since no real ERP credentials ship with the system.
model ConstructionErpConnection {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id])
  provider   String // "manual", "procore", "buildertrend" — free text
  status     String    @default("NOT_CONFIGURED") // NOT_CONFIGURED | CONNECTED | ERROR
  lastSyncAt DateTime?
  config     Json      @default("{}") // placeholder for future real credentials
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, projectId])
  @@index([tenantId, projectId])
  @@map("construction_erp_connections")
}

/// A manually-recorded or ERP-synced construction progress milestone update.
/// This is what feeds the "construction update" feed shown to buyers.
model ConstructionMilestoneUpdate {
  id                     String    @id @default(uuid())
  tenantId               String    @map("tenant_id")
  tenant                 Tenant    @relation(fields: [tenantId], references: [id])
  projectId              String
  project                Project   @relation(fields: [projectId], references: [id])
  towerId                String?
  tower                  Tower?    @relation(fields: [towerId], references: [id])
  milestoneName          String // e.g. "Foundation complete"
  percentComplete        Int // 0-100
  sourceType             String // MANUAL | ERP_SYNC
  reportedById           String?
  reportedAt             DateTime  @default(now())
  createdAt              DateTime  @default(now())
  // Buyer-facing gate (spec 68.1): raw site upload vs approved customer message are separate steps.
  customerVisibleMessage String?
  approvedForBuyersAt    DateTime?
  approvedForBuyersById  String?

  @@index([tenantId, projectId])
  @@index([projectId, reportedAt])
  @@map("construction_milestone_updates")
}

// === MODULE 4.10: SEARCHABLE PERMISSION-AWARE FILE CABINET ===

/// Lightweight read-cache index for cross-source document search. Queries
/// MediaFile, GeneratedDocument, and BuyerDocument at search time and merges
/// results; this index table exists only if live queries prove too slow.
/// Populated by a periodic rebuildIndex method, not by hooks into other
/// modules' services (to avoid editing files outside this module's scope).
model DocumentSearchIndex {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  sourceType     String // MEDIA_FILE | GENERATED_DOCUMENT | BUYER_DOCUMENT
  sourceId       String
  searchableText String // filename/type/tags concatenated
  leadId         String?
  projectId      String?
  unitId         String?
  updatedAt      DateTime @updatedAt

  @@index([tenantId, sourceType])
  @@index([tenantId, leadId])
  @@index([tenantId, projectId])
  @@index([tenantId, unitId])
  @@map("document_search_index")
}

// === MODULE 4.11: PHYSICAL DOCUMENT CUSTODY TRACKING ===

/// Tracks physical paper originals (signed agreements, registered documents)
/// kept in a filing cabinet — who checked them out, when they're due back,
/// and whether they've been returned. Independent of digital GeneratedDocument.
model PhysicalDocumentCustody {
  id                  String     @id @default(uuid())
  tenantId            String     @map("tenant_id")
  tenant              Tenant     @relation(fields: [tenantId], references: [id])
  fileNumber          String // physical folder/file label
  bookingId           String?
  booking             Booking?   @relation(fields: [bookingId], references: [id])
  leadId              String?
  lead                Lead?      @relation("PhysicalDocumentLead", fields: [leadId], references: [id])
  documentDescription String
  location            String // e.g. "Head Office Cabinet 3, Shelf B"
  checkedOutById      String?
  checkedOutBy        User?      @relation("PhysicalDocumentCheckedOutBy", fields: [checkedOutById], references: [id])
  checkedOutAt        DateTime?
  dueBackAt           DateTime?
  returnedAt          DateTime?
  scanLinkMediaFileId String?
  scanLinkMediaFile   MediaFile? @relation("PhysicalDocumentScanMedia", fields: [scanLinkMediaFileId], references: [id])
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([tenantId, fileNumber])
  @@index([tenantId, leadId])
  @@index([tenantId, bookingId])
  @@index([tenantId, returnedAt])
  @@map("physical_document_custodies")
}

/// A tenant-configured overdue-interest rule (spec 67.4) — rate/grace period
/// are the builder's own policy, never hardcoded here. computeOverdueCharge
/// snapshots the policy version used on the resulting LedgerEntry so a later
/// rate change never rewrites an already-charged milestone.
model InterestPolicy {
  id                  String   @id @default(uuid())
  tenantId            String   @map("tenant_id")
  tenant              Tenant   @relation(fields: [tenantId], references: [id])
  name                String
  ratePercentPerMonth Float
  graceDays           Int      @default(0)
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId, active])
  @@map("interest_policies")
}

enum CreditNoteType {
  WAIVER
  CORRECTION

  @@map("credit_note_type")
}

/// An explicit, audited reduction to what a buyer owes — a waiver or a
/// correction — so a discount never just vanishes as an unexplained ledger
/// edit (spec 67.4).
model CreditNote {
  id           String         @id @default(uuid())
  tenantId     String         @map("tenant_id")
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  bookingId    String
  booking      Booking        @relation(fields: [bookingId], references: [id])
  type         CreditNoteType
  amountPaise  BigInt
  reason       String
  approvedById String?
  approvedBy   User?          @relation(fields: [approvedById], references: [id])
  createdAt    DateTime       @default(now())

  @@index([tenantId, bookingId])
  @@map("credit_notes")
}

enum LoanSanctionStatus {
  NOT_APPLIED
  APPLIED
  SANCTIONED
  REJECTED

  @@map("loan_sanction_status")
}

enum LoanDisbursementStatus {
  NOT_REQUESTED
  REQUESTED
  PARTIAL
  COMPLETE

  @@map("loan_disbursement_status")
}

enum NocStatus {
  NOT_REQUESTED
  REQUESTED
  RECEIVED

  @@map("noc_status")
}

/// Loan and registration coordination (spec 67.2) — this app tracks staff-
/// confirmed status, it never performs bank underwriting or government
/// registration itself.
model LoanRegistrationCase {
  id                        String                 @id @default(uuid())
  tenantId                  String                 @map("tenant_id")
  tenant                    Tenant                 @relation(fields: [tenantId], references: [id])
  bookingId                 String                 @unique
  booking                   Booking                @relation(fields: [bookingId], references: [id])
  lenderName                String?
  loanAmountPaise           BigInt?
  sanctionStatus            LoanSanctionStatus     @default(NOT_APPLIED)
  sanctionDate              DateTime?
  disbursementStatus        LoanDisbursementStatus @default(NOT_REQUESTED)
  disbursedAmountPaise      BigInt?
  registrationAppointmentAt DateTime?
  registrationChargesPaise  BigInt?
  registrationReceiptNumber String?
  registeredAt              DateTime?
  bankNocStatus             NocStatus              @default(NOT_REQUESTED)
  notes                     String?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  @@index([tenantId])
  @@map("loan_registration_cases")
}

/// A public browsing session for the buyer-facing digital sales room — not an
/// authenticated staff user (spec 62.4).
model BuyerSession {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  phone       String?
  email       String?
  name        String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  shortlist        UnitShortlist[]
  checkoutHolds    CheckoutHold[]
  checkoutAttempts CheckoutAttempt[]
  events           DigitalSalesEvent[]

  @@index([tenantId])
  @@index([leadId])
  @@map("buyer_sessions")
}

/// Buyer's saved units in the digital sales room (spec 62.2 "saved shortlist/cart").
model UnitShortlist {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  buyerSessionId String
  buyerSession   BuyerSession @relation(fields: [buyerSessionId], references: [id], onDelete: Cascade)
  unitId         String
  unit           Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([buyerSessionId, unitId])
  @@index([tenantId])
  @@map("unit_shortlists")
}

enum CheckoutHoldStatus {
  ACTIVE
  CONSUMED
  EXPIRED
  RELEASED

  @@map("checkout_hold_status")
}

/// A public buyer's short-lived (10-20 min) reservation on a unit during
/// online checkout — separate from the salesperson UnitHold, never manually
/// extended, auto-released unless a verified payment/booking transition lands
/// first (spec 62.3).
model CheckoutHold {
  id             String             @id @default(uuid())
  tenantId       String             @map("tenant_id")
  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  unitId         String
  unit           Unit               @relation(fields: [unitId], references: [id], onDelete: Cascade)
  buyerSessionId String
  buyerSession   BuyerSession       @relation(fields: [buyerSessionId], references: [id], onDelete: Cascade)
  status         CheckoutHoldStatus @default(ACTIVE)
  expiresAt      DateTime
  releasedAt     DateTime?
  createdAt      DateTime           @default(now())

  paymentIntents PaymentIntent[]

  @@index([tenantId, status])
  @@index([unitId, status])
  @@index([expiresAt])
  @@map("checkout_holds")
}

enum CheckoutAttemptStatus {
  STARTED
  PAYMENT_PENDING
  PAYMENT_CONFIRMED
  ABANDONED
  FAILED

  @@map("checkout_attempt_status")
}

/// One buyer's attempt to complete online checkout for one unit — the
/// server-side record of the "checkout wizard" (spec 62.2), independent of
/// PaymentIntent so an abandoned checkout is still visible for follow-up.
model CheckoutAttempt {
  id             String                @id @default(uuid())
  tenantId       String                @map("tenant_id")
  tenant         Tenant                @relation(fields: [tenantId], references: [id])
  buyerSessionId String
  buyerSession   BuyerSession          @relation(fields: [buyerSessionId], references: [id], onDelete: Cascade)
  unitId         String
  unit           Unit                  @relation(fields: [unitId], references: [id], onDelete: Cascade)
  status         CheckoutAttemptStatus @default(STARTED)
  bookingId      String?
  booking        Booking?              @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([tenantId, status])
  @@index([buyerSessionId])
  @@map("checkout_attempts")
}

enum PaymentIntentStatus {
  CREATED
  PENDING
  CONFIRMED
  FAILED
  CANCELLED

  @@map("payment_intent_status")
}

/// A token/booking-amount payment attempt through a real payment gateway.
/// Never trust the browser redirect — only a verified signed webhook may move
/// this to CONFIRMED (spec 62.3). `provider` stays null and status stays
/// CREATED forever if no gateway is configured for the tenant; the checkout
/// UI must show "payments not configured" rather than fake success.
model PaymentIntent {
  id             String              @id @default(uuid())
  tenantId       String              @map("tenant_id")
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  checkoutHoldId String?
  checkoutHold   CheckoutHold?       @relation(fields: [checkoutHoldId], references: [id], onDelete: SetNull)
  provider       String?
  providerRef    String?
  amountPaise    BigInt
  status         PaymentIntentStatus @default(CREATED)
  webhookEventId String?             @unique
  confirmedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([tenantId, status])
  @@index([checkoutHoldId])
  @@map("payment_intents")
}

/// Immutable behavioural events for the digital sales room funnel report
/// (spec 62.4/66.3) — unit.viewed, unit.shortlisted, checkout.started, etc.
model DigitalSalesEvent {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  tenant         Tenant       @relation(fields: [tenantId], references: [id])
  buyerSessionId String
  buyerSession   BuyerSession @relation(fields: [buyerSessionId], references: [id], onDelete: Cascade)
  eventType      String
  unitId         String?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())

  @@index([tenantId, eventType])
  @@index([buyerSessionId])
  @@map("digital_sales_events")
}

enum LandingPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@map("landing_page_status")
}

/// A published marketing landing page built from approved components (spec
/// 66.1) — content only, no arbitrary script injection; forms on it create
/// leads through the normal lead-ingestion path.
model LandingPage {
  id          String            @id @default(uuid())
  tenantId    String            @map("tenant_id")
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  projectId   String?
  project     Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  slug        String
  title       String
  content     Json              @default("{}")
  status      LandingPageStatus @default(DRAFT)
  utmDefaults Json              @default("{}")
  publishedAt DateTime?
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("landing_pages")
}

/// A saved, reusable lead filter used by campaigns/journeys (spec 66.1) — a
/// definition, not a frozen snapshot, so it stays live as leads change.
model AudienceSegment {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  name        String
  filters     Json     @default("{}")
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@map("audience_segments")
}

enum SuppressionChannel {
  WHATSAPP
  SMS
  EMAIL
  CALL

  @@map("suppression_channel")
}

/// An opt-out record — an opted-out contact never receives a non-essential
/// send on that channel again (spec 51/66.1). Checked before every bulk
/// send, not just campaign sends.
model SuppressionEntry {
  id         String             @id @default(uuid())
  tenantId   String             @map("tenant_id")
  tenant     Tenant             @relation(fields: [tenantId], references: [id])
  channel    SuppressionChannel
  contactRef String
  reason     String?
  createdAt  DateTime           @default(now())

  @@unique([tenantId, channel, contactRef])
  @@index([tenantId])
  @@map("suppression_entries")
}

/// An imported ad-spend batch, kept separate from leads so "cost per booking"
/// reports can join spend to leads by project/campaign/date without
/// conflating the two data sources (spec 66.1/25).
model AdSpendImport {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  source      String
  campaign    String?
  spendDate   DateTime
  amountPaise BigInt
  currency    String   @default("INR")
  createdById String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([projectId, spendDate])
  @@map("ad_spend_imports")
}

/// Tracks per-tenant onboarding-wizard progress with an explicit validator
/// per step, not a vague "setup complete" flag (spec 54.2).
model TenantOnboardingStep {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  stepKey       String
  status        String    @default("NOT_STARTED")
  completedAt   DateTime?
  completedById String?
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, stepKey])
  @@index([tenantId])
  @@map("tenant_onboarding_steps")
}
