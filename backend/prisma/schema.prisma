generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  SALES_AGENT
  SUPPORT_AGENT
  VIEWER
}

// === TENANT MODEL ===

model SavedReport {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  entity    String
  config    Json
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  isShared  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([ownerId])
  @@map("saved_reports")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  domain    String?
  plan      String   @default("starter")
  active    Boolean  @default(true)
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                        User[]
  contacts                     Contact[]
  leads                        Lead[]
  campaigns                    Campaign[]
  integrations                 Integration[]
  tickets                      Ticket[]
  knowledgeArticles            KnowledgeArticle[]
  copilotConversations         CopilotConversation[]
  savedReports                 SavedReport[]
  callLogs                     CallLog[]
  notifications                Notification[]
  adCampaigns                  AdCampaign[]
  events                       Event[]
  devices                      Device[]
  bookings                     Booking[]
  properties                   Property[]
  shipments                    Shipment[]
  paymentSchedules             PaymentSchedule[]
  channelPartners              ChannelPartner[]
  projects                     Project[]
  units                        Unit[]
  mediaCollections             MediaCollection[]
  siteVisits                   SiteVisit[]
  unitHolds                    UnitHold[]
  costSheets                   CostSheet[]
  offers                       Offer[]
  buyerDocuments               BuyerDocument[]
  kycVerifications             KycVerification[]
  documentTemplates            DocumentTemplate[]
  generatedDocuments           GeneratedDocument[]
  esignRequests                ESignRequest[]
  paymentReceipts              PaymentReceipt[]
  ledgerEntries                LedgerEntry[]
  partnerPortalUsers           PartnerPortalUser[]
  partnerLeadClaims            PartnerLeadClaim[]
  commissionPlans              CommissionPlan[]
  commissionAccruals           CommissionAccrual[]
  commissionPayouts            CommissionPayout[]
  integrationEvents            IntegrationEvent[]
  slaBreaches                  SlaBreach[]
  approvalRequests             ApprovalRequest[]
  buyerPortalTokens            BuyerPortalToken[]
  paymentPlanTemplates         PaymentPlanTemplate[]
  marketingJourneys            MarketingJourney[]
  marketingJourneyEnrollments  MarketingJourneyEnrollment[]
  marketingEvents              MarketingEvent[]
  cashFlowForecastEntries      CashFlowForecastEntry[]
  revenueShareParties          RevenueShareParty[]
  revenueShareAllocations      RevenueShareAllocation[]
  resaleListings               ResaleListing[]
  referralPrograms             ReferralProgram[]
  referrals                    Referral[]
  nriBuyerProfiles             NriBuyerProfile[]
  constructionErpConnections   ConstructionErpConnection[]
  constructionMilestoneUpdates ConstructionMilestoneUpdate[]
  physicalDocumentCustodies    PhysicalDocumentCustody[]
  territoryAssignments         TerritoryAssignment[]
  approvalPolicies             ApprovalPolicy[]
  shifts                       Shift[]
  agentAvailabilities          AgentAvailability[]
  callQualityReviews           CallQualityReview[]
  visitAttendances             VisitAttendance[]
  postSalesTransitions         PostSalesTransition[]
  transferCases                TransferCase[]
  unitShiftCases               UnitShiftCase[]
  cancellationCases            CancellationCase[]
  refundCases                  RefundCase[]
  possessionCases              PossessionCase[]
  interestPolicies             InterestPolicy[]
  creditNotes                  CreditNote[]
  loanRegistrationCases        LoanRegistrationCase[]
  projectPhases                ProjectPhase[]
  alliedInventoryItems         AlliedInventoryItem[]
  alliedInventoryAllocations   AlliedInventoryAllocation[]
  inventoryReleaseBatches      InventoryReleaseBatch[]
  salesTargets                 SalesTarget[]
  buyerSessions                BuyerSession[]
  unitShortlists               UnitShortlist[]
  checkoutHolds                CheckoutHold[]
  checkoutAttempts             CheckoutAttempt[]
  paymentIntents               PaymentIntent[]
  digitalSalesEvents           DigitalSalesEvent[]
  landingPages                 LandingPage[]
  audienceSegments             AudienceSegment[]
  suppressionEntries           SuppressionEntry[]
  adSpendImports               AdSpendImport[]
  onboardingSteps              TenantOnboardingStep[]

  @@index([slug])
  @@map("tenants")
}

