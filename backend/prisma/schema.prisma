enum CallSource {
  TWILIO
  SIM
  WHATSAPP
}

model CallLog {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  leadId          String?
  lead            Lead?         @relation(fields: [leadId], references: [id])
  contactId       String?
  contact         Contact?      @relation(fields: [contactId], references: [id])
  agentId         String?
  agent           User?         @relation(fields: [agentId], references: [id])
  direction       CallDirection
  status          CallStatus    @default(INITIATED)
  fromNumber      String
  toNumber        String
  durationSec     Int?
  recordingUrl    String?
  providerSid     String?
  notes           String?
  source          CallSource    @default(TWILIO)
  deviceId        String?
  device          Device?       @relation(fields: [deviceId], references: [id])
  recordedLocally Boolean       @default(false)
  syncedAt        DateTime?
  transcript      String?       @db.Text
  summary         String?
  summaryStatus   String        @default("PENDING")
  disposition     String? // connected_qualified | connected_follow_up | wrong_number | no_answer | busy | switched_off | not_interested | site_visit_scheduled | lost (spec 64.1)
  nextActionAt    DateTime?
  outcome         Json? // structured data extracted by the voice agent (e.g. Dograh call outcomes: property_type, area, bhk, budget, timeline, needs_loan, wants_site_visit)
  createdAt       DateTime      @default(now())

  callSyncLogs   CallSyncLog[]
  qualityReviews CallQualityReview[]

  @@index([tenantId])
  @@index([leadId])
  @@index([deviceId])
  @@map("call_logs")
}

enum AgentAvailabilityStatus {
  AVAILABLE
  ON_CALL
  BREAK
  OFFLINE

  @@map("agent_availability_status")
}

/// Fixed working-hours block a user can be assigned to (spec 64.2), e.g. "Morning 9-2".
model Shift {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  name       String
  startTime  String // "HH:MM", local to tenant
  endTime    String
  daysOfWeek Int[]    @default([]) // 0=Sunday .. 6=Saturday
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  assignments AgentAvailability[]

  @@index([tenantId])
  @@map("shifts")
}

/// Current live status of a call-centre agent (spec 64.2) — one row per user, upserted as status changes.
model AgentAvailability {
  id        String                  @id @default(uuid())
  tenantId  String                  @map("tenant_id")
  tenant    Tenant                  @relation(fields: [tenantId], references: [id])
  userId    String                  @unique
  user      User                    @relation(fields: [userId], references: [id])
  shiftId   String?
  shift     Shift?                  @relation(fields: [shiftId], references: [id])
  status    AgentAvailabilityStatus @default(OFFLINE)
  since     DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([tenantId])
  @@map("agent_availabilities")
}

/// Manager QA scoring of a completed call (spec 64.2) for coaching visibility.
model CallQualityReview {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  callLogId  String
  callLog    CallLog  @relation(fields: [callLogId], references: [id], onDelete: Cascade)
  reviewerId String?
  reviewer   User?    @relation(fields: [reviewerId], references: [id])
  score      Int // 0-100
  notes      String?
  criteria   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([callLogId])
  @@map("call_quality_reviews")
}

/// Field check-in for a site visit (spec 64.2) — GPS-consented or manual fallback; never used alone for employment decisions.
model VisitAttendance {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  siteVisitId   String
  siteVisit     SiteVisit @relation(fields: [siteVisitId], references: [id], onDelete: Cascade)
  checkedInById String?
  checkedInBy   User?     @relation(fields: [checkedInById], references: [id])
  method        String    @default("MANUAL") // GPS | MANUAL
  lat           Float?
  lng           Float?
  checkedInAt   DateTime  @default(now())

  @@index([tenantId])
  @@index([siteVisitId])
  @@map("visit_attendances")
}

model CallSyncLog {
  id            String           @id @default(uuid())
  tenantId      String           @map("tenant_id")
  callLogId     String           @map("call_log_id")
  callLog       CallLog          @relation(fields: [callLogId], references: [id])
  integrationId String?          @map("integration_id")
  integration   Integration?     @relation(fields: [integrationId], references: [id])
  webhookId     String?          @map("webhook_id")
  webhook       OutboundWebhook? @relation(fields: [webhookId], references: [id])
  crmType       String? // hubspot, salesforce, zoho, webhook
  status        String // SUCCESS | FAILED
  error         String?
  attemptAt     DateTime         @default(now())

  @@index([tenantId])
  @@index([callLogId])
  @@index([status])
  @@map("call_sync_logs")
}

model Device {
  id                   String    @id @default(uuid())
  tenantId             String    @map("tenant_id")
  tenant               Tenant    @relation(fields: [tenantId], references: [id])
  userId               String
  user                 User      @relation(fields: [userId], references: [id])
  name                 String?
  platform             String    @default("android")
  model                String?
  apiKeyHash           String?   @unique
  pairingCode          String?   @unique
  pairingCodeExpiresAt DateTime?
  lastSeenAt           DateTime?
  revokedAt            DateTime?
  createdAt            DateTime  @default(now())

  callLogs CallLog[]

  @@index([tenantId])
  @@index([userId])
  @@map("devices")
}

