generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  SALES_AGENT
  SUPPORT_AGENT
  VIEWER
}

// === TENANT MODEL ===

model SavedReport {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  entity    String
  config    Json
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  isShared  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([ownerId])
  @@map("saved_reports")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  domain    String?
  plan      String   @default("starter")
  active    Boolean  @default(true)
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  contacts   Contact[]
  leads      Lead[]
  campaigns  Campaign[]
  integrations Integration[]
  tickets      Ticket[]
  knowledgeArticles KnowledgeArticle[]
  copilotConversations CopilotConversation[]
  savedReports SavedReport[]
  callLogs     CallLog[]
  notifications Notification[]
  adCampaigns AdCampaign[]
  events        Event[]
  devices       Device[]
  bookings      Booking[]
  properties    Property[]
  shipments     Shipment[]
  paymentSchedules PaymentSchedule[]
  channelPartners  ChannelPartner[]
  projects         Project[]
  units            Unit[]
  mediaCollections MediaCollection[]

  @@index([slug])
  @@map("tenants")
}

enum LeadSource {
  CAMPAIGN
  QR_CODE
  FORM
  CHATBOT
  MOBILE_APP
  WHATSAPP
  SOCIAL_MEDIA
  PHONE_CALL
  TELEGRAM
  EMAIL
  META_ADS
  GOOGLE_ADS
  INDIAMART
  NINETY_NINE_ACRES
  JUSTDIAL
  MAGICBRICKS
  HOUSING_COM
  TRADEINDIA
  MANUAL
  REFERRAL
}

enum LeadStatus {
  NEW
  CONTACTED
  ENGAGED
  QUALIFYING
  QUALIFIED
  PROPOSAL_SENT
  APPOINTMENT_BOOKED
  CONVERTED
  LOST
  COLD
  SPAM
}

enum LeadSegment {
  HOT
  WARM
  COLD
  UNQUALIFIED
  EXISTING_CUSTOMER
  RECONNECT
}

enum MessageChannel {
  WHATSAPP
  EMAIL
  SMS
  CHATBOT
  SOCIAL_DM
  PHONE_CALL
  SYSTEM
  TELEGRAM
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  NO_ANSWER
  BUSY
  MISSED
}

enum CallSource {
  TWILIO
  SIM
  WHATSAPP
}

model CallLog {
  id              String        @id @default(uuid())
  tenantId        String        @map("tenant_id")
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  leadId          String?
  lead            Lead?         @relation(fields: [leadId], references: [id])
  contactId       String?
  contact         Contact?      @relation(fields: [contactId], references: [id])
  agentId         String?
  agent           User?         @relation(fields: [agentId], references: [id])
  direction       CallDirection
  status          CallStatus    @default(INITIATED)
  fromNumber      String
  toNumber        String
  durationSec     Int?
  recordingUrl    String?
  providerSid     String?
  notes           String?
  source          CallSource    @default(TWILIO)
  deviceId        String?
  device          Device?       @relation(fields: [deviceId], references: [id])
  recordedLocally Boolean       @default(false)
  syncedAt        DateTime?
  transcript      String?       @db.Text
  summary         String?
  summaryStatus   String        @default("PENDING")
  createdAt       DateTime      @default(now())

  callSyncLogs    CallSyncLog[]

  @@index([tenantId])
  @@index([leadId])
  @@index([deviceId])
  @@map("call_logs")
}

model CallSyncLog {
  id            String          @id @default(uuid())
  tenantId      String          @map("tenant_id")
  callLogId     String          @map("call_log_id")
  callLog       CallLog         @relation(fields: [callLogId], references: [id])
  integrationId String?         @map("integration_id")
  integration   Integration?    @relation(fields: [integrationId], references: [id])
  webhookId     String?         @map("webhook_id")
  webhook       OutboundWebhook? @relation(fields: [webhookId], references: [id])
  crmType       String?         // hubspot, salesforce, zoho, webhook
  status        String          // SUCCESS | FAILED
  error         String?
  attemptAt     DateTime        @default(now())

  @@index([tenantId])
  @@index([callLogId])
  @@index([status])
  @@map("call_sync_logs")
}

model Device {
  id                   String    @id @default(uuid())
  tenantId             String    @map("tenant_id")
  tenant               Tenant    @relation(fields: [tenantId], references: [id])
  userId               String
  user                 User      @relation(fields: [userId], references: [id])
  name                 String?
  platform             String    @default("android")
  model                String?
  apiKeyHash           String?   @unique
  pairingCode          String?   @unique
  pairingCodeExpiresAt DateTime?
  lastSeenAt           DateTime?
  revokedAt            DateTime?
  createdAt            DateTime  @default(now())

  callLogs CallLog[]

  @@index([tenantId])
  @@index([userId])
  @@map("devices")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MediaCategory {
  CAMPAIGN_ASSET
  LEAD_ATTACHMENT
  MESSAGE_ATTACHMENT
  BROCHURE
  CATALOG
  PROPOSAL
  QUOTE
  INVOICE
  CASE_STUDY
  DIGITAL_DOWNLOAD
  OTHER
}

enum NurtureStepType {
  SEND_WHATSAPP
  SEND_EMAIL
  SEND_DOCUMENT
  SEND_IMAGE
  SEND_DIGITAL_DOWNLOAD
  CREATE_TASK
  NOTIFY_TEAM
  WAIT
  CHECK_CONDITION
  UPDATE_LEAD_STATUS
  PUSH_TO_CRM
  SEND_BOOKING_LINK
}

enum ConversionDestination {
  CRM_QUALIFIED_PUSH
  APPOINTMENT_BOOKING
  QUOTE_REQUEST
  PURCHASE_ONLINE
  ORDER_BOOKING
  MEMBER_REGISTRATION
  DIGITAL_DOWNLOAD
  USER_SUBSCRIPTION
}

enum ConversionStatus {
  REQUESTED
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum AutomationEventType {
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_SCORED
  LEAD_HOT
  LEAD_QUALIFIED
  LEAD_NO_RESPONSE
  CONVERSATION_MESSAGE_RECEIVED
  CONVERSATION_MESSAGE_SENT
  APPOINTMENT_REQUESTED
  APPOINTMENT_BOOKED
  QUOTE_REQUESTED
  ORDER_CREATED
  PAYMENT_SUCCESS
  SUBSCRIPTION_STARTED
  DIGITAL_DOWNLOAD_REQUESTED
  DIGITAL_DOWNLOAD_DELIVERED
  MEDIA_UPLOADED
  MEDIA_ATTACHED
  CRM_PUSH_REQUESTED
}

enum MessageTemplateType {
  WELCOME
  QUALIFICATION_QUESTION
  FOLLOW_UP
  RECONNECT
  APPOINTMENT_LINK
  QUOTE_REQUEST
  PAYMENT_LINK
  CRM_CONFIRMATION
  DIGITAL_DOWNLOAD
  THANK_YOU
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  DROPDOWN
  MULTI_SELECT
}

enum CustomFieldTarget {
  CONTACT
  LEAD
  TICKET
  TEAM_MEMBER
}

// === REFRESH TOKENS ===

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// === PASSWORD RESET TOKEN ===

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

// === USER MODEL ===

model User {
  id        String   @id @default(uuid())
  tenantId  String  @map("tenant_id")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  email     String   @unique
  phone     String?
  password  String
  role      UserRole @default(SALES_AGENT)
  active    Boolean  @default(true)
  emailVerifiedAt DateTime?
  mfaEnabled  Boolean  @default(false)
  mfaSecret   String?
  lockoutUntil    DateTime?
  failedLoginAttempts Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedLeads    Lead[]
  createdCampaigns Campaign[]        @relation("CampaignCreator")
  assignedCampaigns Campaign[]       @relation("CampaignAssignee")
  createdTemplates MessageTemplate[]
  createdMedia     MediaFile[]       @relation("MediaUploader")
  auditLogs        AuditLog[]
  tasks            Task[]
  savedFilters     SavedFilter[]
  internalNotes    InternalNote[]
  notificationPrefs NotificationPreference[]
  importExportLogs ImportExportLog[]
  ownershipFrom    LeadOwnershipHistory[] @relation("OwnershipFromUser")
  ownershipTo      LeadOwnershipHistory[] @relation("OwnershipToUser")
  ownershipChanged LeadOwnershipHistory[] @relation("OwnershipChangedBy")
  escalatedSla     SlaRule[]
  assignedTickets  Ticket[]
  ticketComments   TicketComment[]
  knowledgeArticles KnowledgeArticle[]
  copilotConversations CopilotConversation[]
  savedReports SavedReport[]
  callLogs     CallLog[]
  notifications Notification[]
  devices       Device[]
  eventAssignments EventTeamAssignment[]
  leaveRequests    LeaveRequest[] @relation("LeaveRequestUser")
  approvedLeaveRequests LeaveRequest[] @relation("LeaveRequestApprover")
  salaryRecords    SalaryRecord[]
  timesheetEntries TimesheetEntry[]
  modulePermissions ModulePermission[] @relation("ModulePermissionUser")
  customFieldValues CustomFieldValue[] @relation("CustomFieldValueUser")
  department       String?
  salaryType       String?
  monthlySalary    Float?
  joinedDate       DateTime?
  skills           String[] @default([])
  annualLeaveQuota Int?
  teamStatus       String?

  @@index([email])
  @@index([role])
  @@map("users")
}

model BusinessSettings {
  id                    String   @id @default(uuid())
  // Enforces a single row at the DB level (upsert on this unique field is atomic),
  // instead of relying on an app-level find-then-create check that two concurrent
  // callers (e.g. boot-time config reconcile racing an API request) could both pass.
  singleton             Boolean  @unique @default(true)
  businessName          String   @default("")
  timezone              String   @default("UTC")
  defaultCurrency       String   @default("USD")
  defaultWhatsAppNumber String?
  defaultEmail          String?
  defaultCrm            String?
  defaultBookingTool    String?
  workingHoursStart     String?
  workingHoursEnd       String?
  quietHoursStart       String?   // e.g. "21:00"
  quietHoursEnd         String?   // e.g. "09:00"
  autonomyLevel         String   @default("full")  // shadow | approval | full
  consentRequired       Boolean  @default(true)
  maxMessagesPerDay     Int      @default(10)
  notificationEmail     String?
  notificationPhone     String?
  logoUrl               String?
  faviconUrl            String?
  primaryColor          String   @default("#0B5")
  labels                Json     @default("{}")
  industry              String?
  toneExamples          String[] @default([])
  goals                 String[] @default([])
  compliance            String[] @default([])
  inventoryEnforcement  String   @default("ADVISORY") // ADVISORY | STRICT — governs event inventory over-allocation
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("business_settings")
}

model Contact {
  id               String   @id @default(uuid())
  tenantId         String  @map("tenant_id")
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  version          Int      @default(0)
  deletedAt        DateTime?
  name             String?
  email            String?
  phone            String?
  whatsapp         String?
  company          String?
  location         String?
  preferredChannel String?
  metadata         Json     @default("{}")
  tags             String[] @default([])
  consentStatus    String   @default("unknown")   // unknown | opted_in | opted_out
  consentSource    String?
  consentAt        DateTime?
  optedOutAt       DateTime?
  agentMemory      Json?                           // Bounded summary for the LLM agent
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  leads          Lead[]
  conversations  ConversationMessage[]
  mediaFiles     MediaFile[]       @relation("ContactMedia")
  customFields   CustomFieldValue[]
  systemEvents   SystemEvent[]
  timelineItems  TimelineItem[]
  consentEvents  ConsentEvent[]
  tickets        Ticket[]
  callLogs       CallLog[]
  events         Event[]
  invoices       Invoice[]
  quotations     Quotation[]
  contracts      Contract[]

  @@index([email])
  @@index([phone])
  @@index([whatsapp])
  @@map("contacts")
}

model Lead {
  id           String      @id @default(uuid())
  tenantId     String  @map("tenant_id")
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  version      Int         @default(0)
  deletedAt    DateTime?
  status       LeadStatus  @default(NEW)
  segment      LeadSegment @default(COLD)
  source       LeadSource
  score        Int         @default(0)
  priority     Int         @default(0)
  interest     String?
  budget       String?
  dealValue    Float?
  urgency      String?
  message      String?
  tags         String[]    @default([])
  metadata     Json        @default("{}")
  campaignId   String?
  qualifiedAt  DateTime?
  convertedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  contactId       String
  contact         Contact         @relation(fields: [contactId], references: [id])
  assignedAgentId String?
  assignedAgent   User?           @relation(fields: [assignedAgentId], references: [id])

  campaign        Campaign?       @relation(fields: [campaignId], references: [id])
  conversations   ConversationMessage[]
  mediaFiles      MediaFile[]     @relation("LeadMedia")
  nurtureProgress NurtureProgress[]
  tasks           Task[]
  conversions     Conversion[]
  scoreLogs       ScoreLog[]
  customFields    CustomFieldValue[]
  ownershipHistory LeadOwnershipHistory[]
  internalNotes  InternalNote[]
  revenueRecords RevenueRecord[]
  submissions    FormSubmission[]
  systemEvents   SystemEvent[]
  timelineItems  TimelineItem[]
  failureRecords FailureRecord[]
  workflowInstances WorkflowInstance[]
  scheduledActions  ScheduledAction[]
  tickets           Ticket[]
  callLogs          CallLog[]
  events            Event[]
  bookings          Booking[]
  shipments         Shipment[]
  paymentSchedules  PaymentSchedule[]
  bookedUnits       Unit[]

  channelPartnerId String?
  channelPartner   ChannelPartner? @relation(fields: [channelPartnerId], references: [id])

  @@index([status])
  @@index([segment])
  @@index([score])
  @@index([source])
  @@index([campaignId])
  @@index([assignedAgentId])
  @@index([contactId])
  @@index([createdAt])
  @@index([channelPartnerId])
  @@map("leads")
}

model ConsentEvent {
  id        String   @id @default(uuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  channel   String   // whatsapp | email | sms | all
  action    String   // opt_in | opt_out
  source    String?  // webhook | form | agent | manual
  createdAt DateTime @default(now())

  @@index([contactId])
  @@map("consent_events")
}

model Campaign {
  id                String    @id @default(uuid())
  tenantId          String  @map("tenant_id")
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  name              String
  description       String?
  sourceType        LeadSource
  campaignType      String   @default("multi-channel")

  // Offer & destination
  offer             String?
  landingUrl        String?
  conversionGoal    String?
  crmDestination    String?
  bookingDestination String?

  // Status & schedule
  active            Boolean   @default(true)
  status            String    @default("draft") // draft, active, paused, completed, archived
  startDate         DateTime?
  endDate           DateTime?
  priority          Int       @default(0)

  // Budget: { total: number, daily: number, spent: number, currency: string }
  budget            Json      @default("{}")

  // Targeting: { propertyTypes: string[], budgetRanges: string[], locations: string[], buyerType: string, minScore: number }
  targeting         Json      @default("{}")

  // Channels: [{ type: string, config: {}, active: boolean }]
  channels          Json      @default("[]")

  // Creatives: [{ name, type, headline, body, cta, imageUrl, thumbnailUrl, variant, performance: { impressions, clicks, conversions } }]
  creatives         Json      @default("[]")

  // UTM
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmTerm           String?
  utmContent        String?

  // Metrics (computed/updated by performance endpoint)
  totalBudget       Float?    @default(0)
  dailyBudget       Float?    @default(0)
  totalSpend        Float?    @default(0)
  costPerLead       Float?
  roi               Float?
  totalLeads        Int       @default(0)
  totalConversions  Int       @default(0)

  tags              String[]  @default([])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  creatorId       String
  creator         User               @relation("CampaignCreator", fields: [creatorId], references: [id])
  assignedAgentId String?
  assignedAgent   User?              @relation("CampaignAssignee", fields: [assignedAgentId], references: [id])
  formId          String?
  form            LeadForm?          @relation(fields: [formId], references: [id])
  qrCodeId        String?
  qrCode          QrCode?            @relation(fields: [qrCodeId], references: [id])
  nurtureId       String?
  nurtureSequence NurtureSequence?   @relation(fields: [nurtureId], references: [id])
  leads           Lead[]
  mediaFiles      MediaFile[]        @relation("CampaignMedia")
  conversations   ConversationMessage[]
  timeline        CampaignTimelineEntry[]

  @@index([active])
  @@index([sourceType])
  @@index([status])
  @@map("campaigns")
}

model CampaignTimelineEntry {
  id        String   @id @default(uuid())
  campaignId String
  campaign  Campaign @relation(fields: [campaignId], references: [id])
  event     String   // created, activated, paused, completed, budget_changed, creative_added, etc.
  detail    String?
  metadata  Json     @default("{}")
  userId    String?
  createdAt DateTime @default(now())

  @@map("campaign_timeline")
}

model LeadForm {
  id        String   @id @default(uuid())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Multi-step config: array of { id, title, description }
  steps Json @default("[]")

  // Embed config: { type: 'inline'|'popup'|'slide', theme: {...} }
  embedConfig Json @default("{}")

  // Post-submission: { redirectUrl, confirmationMessage, sendConfirmationEmail, emailTemplateId }
  submissionConfig Json @default("{}")

  // Form type hint for template selection
  formType String @default("custom")

  fields      LeadFormField[]
  submissions FormSubmission[]
  campaigns   Campaign[]

  @@map("lead_forms")
}

model LeadFormField {
  id          String  @id @default(uuid())
  label       String
  fieldKey    String
  type        String
  required    Boolean @default(false)
  placeholder String?
  description String?
  validation  Json    @default("{}")
  options     Json    @default("[]")
  displayOrder Int   @default(0)

  // Multi-step: which step this field belongs to
  stepId String @default("")

  // Conditional logic: { action: 'show'|'hide'|'require', conditions: [{ fieldKey, operator: 'eq'|'neq'|'gt'|'lt'|'in'|'contains', value }] }
  conditionalLogic Json @default("{}")

  // Layout: width (full/half/third), icon
  width String @default("full")

  formId String
  form   LeadForm @relation(fields: [formId], references: [id])

  @@map("lead_form_fields")
}

model FormSubmission {
  id        String   @id @default(uuid())
  payload   Json
  formId    String
  form      LeadForm @relation(fields: [formId], references: [id])
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id])

  // Source tracking
  source    String @default("direct")
  pageUrl   String?
  utm       Json   @default("{}")

  // Completion tracking
  completed Boolean @default(true)
  startedAt DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@map("form_submissions")
}

model QrCode {
  id           String   @id @default(uuid())
  name         String
  destinationType String
  destination  String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scans    QrScan[]
  campaigns Campaign[]

  @@map("qr_codes")
}

model QrScan {
  id        String   @id @default(uuid())
  qrCodeId  String
  qrCode    QrCode   @relation(fields: [qrCodeId], references: [id])
  country   String?
  city      String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([qrCodeId])
  @@map("qr_scans")
}

model ConversationMessage {
  id                String          @id @default(uuid())
  text              String
  providerMessageId String?
  deliveryStatus    String          @default("pending")
  channel           MessageChannel
  direction         MessageDirection
  metadata          Json            @default("{}")
  messageTemplateId String?
  messageTemplate   MessageTemplate? @relation(fields: [messageTemplateId], references: [id])
  leadId            String
  lead              Lead            @relation(fields: [leadId], references: [id])
  contactId         String?
  contact           Contact?        @relation(fields: [contactId], references: [id])
  campaignId        String?
  campaign          Campaign?       @relation(fields: [campaignId], references: [id])
  createdAt         DateTime        @default(now())

  @@index([leadId])
  @@index([contactId, createdAt])
  @@index([campaignId])
  @@index([providerMessageId])
  @@index([channel])
  @@index([direction])
  @@map("conversation_messages")
}

model MessageTemplate {
  id        String              @id @default(uuid())
  name      String
  type      MessageTemplateType
  channel   MessageChannel
  body      String
  variables Json                @default("[]")
  version   Int                 @default(1)
  active    Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  creatorId         String
  creator           User                  @relation(fields: [creatorId], references: [id])
  mediaFiles        MediaFile[]           @relation("TemplateMedia")
  conversationMsgs  ConversationMessage[]
  nurtureSteps      NurtureStep[]

  @@map("message_templates")
}

model MediaCollection {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  description String?
  coverImageUrl String?
  projectId String?
  propertyId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  items  MediaCollectionItem[]

  @@index([tenantId])
  @@map("media_collections")
}

model MediaCollectionItem {
  id           String         @id @default(uuid())
  collectionId String
  collection   MediaCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  mediaId      String
  media        MediaFile       @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  orderIndex   Int            @default(0)
  createdAt    DateTime       @default(now())

  @@unique([collectionId, mediaId])
  @@index([mediaId])
  @@map("media_collection_items")
}

model MediaFile {
  id             String        @id @default(uuid())
  fileName       String
  originalName   String
  fileType       String
  mimeType       String
  fileSize       Int
  storageProvider String       @default("local")
  storageKey     String
  publicUrl      String?
  signedUrl      String?
  category       MediaCategory @default(OTHER)
  tags           String[]      @default([])
  isDigitalDownload Boolean    @default(false)
  downloadStatus String?
  projectId      String?
  propertyId     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  uploadedById String
  uploadedBy   User            @relation("MediaUploader", fields: [uploadedById], references: [id])
  leadId       String?
  lead         Lead?           @relation("LeadMedia", fields: [leadId], references: [id])
  campaignId   String?
  campaign     Campaign?       @relation("CampaignMedia", fields: [campaignId], references: [id])
  contactId    String?
  contact      Contact?        @relation("ContactMedia", fields: [contactId], references: [id])
  templateId   String?
  template     MessageTemplate? @relation("TemplateMedia", fields: [templateId], references: [id])
  collections  MediaCollectionItem[]

  @@index([category])
  @@index([fileType])
  @@index([createdAt])
  @@index([leadId])
  @@index([campaignId])
  @@index([templateId])
  @@index([projectId])
  @@index([propertyId])
  @@map("media_files")
}

model NurtureSequence {
