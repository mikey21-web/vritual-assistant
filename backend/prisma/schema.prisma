  sequenceId    String
  sequence      NurtureSequence  @relation(fields: [sequenceId], references: [id])
  type          NurtureStepType
  displayOrder  Int
  config        Json             @default("{}")
  templateId    String?
  template      MessageTemplate? @relation(fields: [templateId], references: [id])
  waitSeconds   Int              @default(0)
  condition     Json             @default("{}")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("nurture_steps")
}

model NurtureProgress {
  id         String          @id @default(uuid())
  leadId     String
  lead       Lead            @relation(fields: [leadId], references: [id])
  sequenceId String
  sequence   NurtureSequence @relation(fields: [sequenceId], references: [id])
  stepId     String
  status     String          @default("pending")
  dueAt      DateTime?
  executedAt DateTime?
  error      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([leadId])
  @@index([sequenceId])
  @@index([status])
  @@map("nurture_progress")
}

model ScoringRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  field       String
  operator    String
  value       String
  points      Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("scoring_rules")
}

model ScoreLog {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  ruleId    String?
  oldScore  Int
  newScore  Int
  reason    String?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@map("score_logs")
}

model RoutingRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  conditions  Json
  action      Json
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("routing_rules")
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("pending")
  priority    String   @default("medium")
  dueAt       DateTime?
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id])
  assigneeId  String?
  assignee    User?    @relation(fields: [assigneeId], references: [id])
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([assigneeId])
  @@index([leadId])
  @@index([eventId])
  @@map("tasks")
}

model Conversion {
  id             String               @id @default(uuid())
  destination    ConversionDestination
  status         ConversionStatus     @default(REQUESTED)
  externalId     String?
  metadata       Json                 @default("{}")
  leadId         String
  lead           Lead                 @relation(fields: [leadId], references: [id])
  requestedById  String?
  scheduledAt    DateTime?
  duration       Int?
  notes          String?
  completedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([leadId])
  @@index([destination])
  @@index([status])
  @@map("conversions")
}

// === PROPERTY / LISTING (Real Estate) ===

enum PropertyType {
  APARTMENT
  VILLA
  PLOT
  COMMERCIAL
  PENTHOUSE
  DUPLEX
  STUDIO

  @@map("property_type")
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  UNDER_OFFER
  ON_HOLD
  RENTED
  DRAFT

  @@map("property_status")
}

model Property {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  deletedAt     DateTime?
  title         String
  description   String?
  propertyType  PropertyType   @default(APARTMENT)
  status        PropertyStatus @default(AVAILABLE)
  price         Float?
  currency      String         @default("INR")
  bedrooms      Int?
  bathrooms     Int?
  areaSqft      Float?
  areaUnit      String         @default("sqft")
  location      String?
  address       String?
  latitude      Float?
  longitude     Float?
  features      String[]       @default([])
  amenities     String[]       @default([])
  reraId        String?
  metadata      Json           @default("{}")
  featured      Boolean        @default(false)
  availableFrom DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  images  PropertyImage[]
  bookings Booking[]

  @@index([tenantId])
  @@index([propertyType])
  @@index([status])
  @@index([price])
  @@index([location])
  @@index([bedrooms])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid())
  propertyId String   @map("property_id")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  isPrimary  Boolean  @default(false)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([propertyId])
  @@map("property_images")
}

enum ProjectStatus {
  PLANNING
  UNDER_CONSTRUCTION
  READY_TO_MOVE
  COMPLETED

  @@map("project_status")
}

enum UnitStatus {
  AVAILABLE
  BLOCKED
  BOOKED
  SOLD
  ON_HOLD

  @@map("unit_status")
}

/// A builder's development — sold as units inside towers/floors, not flat
/// listings. Separate from Property (broker/resale flat listings) because a
/// builder's inventory has structure (tower → floor → unit) that a broker's
/// standalone listings never need.
model Project {
  id             String        @id @default(uuid())
  tenantId       String        @map("tenant_id")
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  deletedAt      DateTime?
  name           String
  description    String?
  location       String?
  address        String?
  reraId         String?
  status         ProjectStatus @default(UNDER_CONSTRUCTION)
  possessionDate DateTime?
  amenities      String[]      @default([])
  images         Json          @default("[]")
  metadata       Json          @default("{}")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  towers Tower[]
  units  Unit[]

  @@index([tenantId])
  @@index([status])
  @@map("projects")
}

model Tower {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  totalFloors  Int?
  createdAt    DateTime @default(now())

  units Unit[]

  @@index([projectId])
  @@map("towers")
}

/// A single sellable unit inside a project (optionally inside a tower). The
/// availability grid and inventory velocity are both derived from this table's
/// status + statusHistory — no spreadsheet needed.
model Unit {
  id         String     @id @default(uuid())
  tenantId   String     @map("tenant_id")
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  towerId    String?
  tower      Tower?     @relation(fields: [towerId], references: [id], onDelete: SetNull)
  unitNumber String
  floor      Int?
  unitType   String?
  areaSqft   Float?
  price      Float?
  currency   String     @default("INR")
  status     UnitStatus @default(AVAILABLE)
  facing     String?
  leadId     String?
  lead       Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  bookedAt   DateTime?
  soldAt     DateTime?
  metadata   Json       @default("{}")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  statusHistory UnitStatusHistory[]
  bookings      Booking[]

  @@unique([projectId, unitNumber])
  @@index([tenantId])
  @@index([projectId])
  @@index([towerId])
  @@index([status])
  @@index([leadId])
  @@map("units")
}

/// Every status transition a unit goes through, timestamped — this is what
/// makes "units sold this month" a real query instead of a manual count.
model UnitStatusHistory {
  id         String      @id @default(uuid())
  unitId     String
  unit       Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  fromStatus UnitStatus?
  toStatus   UnitStatus
  changedAt  DateTime    @default(now())

  @@index([unitId])
  @@index([changedAt])
  @@map("unit_status_history")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW

  @@map("booking_status")
}

model Booking {
  id            String        @id @default(uuid())
  tenantId      String
  leadId        String
  propertyId    String?       @map("property_id")
  unitId        String?
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime?
  status        BookingStatus @default(PENDING)
  price         Float?
  currency      String        @default("INR")
  paymentLink   String?
  paymentStatus String        @default("pending")
  notes         String?
  metadata      Json          @default("{}")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lead     Lead      @relation(fields: [leadId], references: [id])
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  property Property? @relation(fields: [propertyId], references: [id])
  unit     Unit?     @relation(fields: [unitId], references: [id])
  paymentSchedules PaymentSchedule[]

  @@index([tenantId])
  @@index([leadId])
  @@index([startTime])
  @@map("bookings")
}

enum PaymentScheduleStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED

  @@map("payment_schedule_status")
}

/// A scheduled collection milestone/installment for a lead (optionally tied to a
/// booking) — e.g. real-estate booking amount, agreement, registration, possession.
/// Automated reminders are queued as ScheduledActions on create and cancelled on payment.
model PaymentSchedule {
  id        String                @id @default(uuid())
  tenantId  String                @map("tenant_id")
  tenant    Tenant                @relation(fields: [tenantId], references: [id])
  leadId    String
  lead      Lead                  @relation(fields: [leadId], references: [id])
  bookingId String?
  booking   Booking?              @relation(fields: [bookingId], references: [id])
  label     String
  amount    Float
  currency  String                @default("INR")
  dueDate   DateTime?
  status    PaymentScheduleStatus @default(PENDING)
  paidAt    DateTime?
  notes     String?
  metadata  Json                  @default("{}")
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@index([tenantId])
  @@index([leadId])
  @@index([bookingId])
  @@index([status])
  @@index([dueDate])
  @@map("payment_schedules")
}

enum ChannelPartnerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED

  @@map("channel_partner_status")
}

/// A broker / channel partner who sources leads for the business. In Indian real
/// estate 60-80% of bookings come through channel partners, so this tracks
/// onboarding, allocated leads, and commission terms in one place.
model ChannelPartner {
  id             String               @id @default(uuid())
  tenantId       String               @map("tenant_id")
  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  name           String
  company        String?
  phone          String?
  email          String?
  reraId         String?
  commissionRate Float?               // percent
  status         ChannelPartnerStatus @default(ACTIVE)
  notes          String?
  metadata       Json                 @default("{}")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  leads Lead[]

  @@index([tenantId])
  @@index([status])
  @@map("channel_partners")
}

// === SHIPMENT / CONSIGNMENT (Logistics) ===

enum ShipmentType {
  FTL
  LTL
  AIR_FREIGHT
  SEA_FREIGHT
  EXPRESS
  COURIER

  @@map("shipment_type")
}

enum ShipmentStatus {
  QUOTE_REQUESTED
  QUOTE_SENT
  BOOKED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  EXCEPTION

  @@map("shipment_status")
}

enum CargoType {
  GENERAL
  PERISHABLE
  FRAGILE
  HAZARDOUS
  OVERSIZED
  VEHICLE
  ELECTRONICS

  @@map("cargo_type")
}

model Shipment {
  id                  String        @id @default(uuid())
  tenantId            String        @map("tenant_id")
  leadId              String
  title               String?
  origin              String
