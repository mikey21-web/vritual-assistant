// === CORE ENGINE MODELS ===

model SystemEvent {
  id              String    @id @default(uuid())
  type            String
  source          String    @default("system")
  status          String    @default("pending")
  entityType      String?
  entityId        String?
  leadId          String?
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contactId       String?
  contact         Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  campaignId      String?
  payload         Json      @default("{}")
  metadata        Json?
  correlationId   String?
  idempotencyKey  String?   @unique
  createdById     String?
  createdAt       DateTime  @default(now())
  processedAt     DateTime?

  @@index([type])
  @@index([status])
  @@index([leadId])
  @@index([contactId])
  @@index([entityType, entityId])
  @@index([correlationId])
  @@index([idempotencyKey])
  @@index([createdAt])
  @@map("system_events")
}

model AutomationRule {
  id          String    @id @default(uuid())
  name        String
  description String?
  category    String
  eventType   String?
  priority    Int       @default(100)
  conditions  Json
  actions     Json
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  executions  RuleExecution[]

  @@index([category])
  @@index([eventType])
  @@index([active])
  @@index([priority])
  @@map("automation_rules")
}

model RuleExecution {
  id        String    @id @default(uuid())
  ruleId    String
  rule      AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  eventId   String?
  result    String
  input     Json      @default("{}")
  output    Json?
  error     String?
  createdAt DateTime  @default(now())

  @@index([ruleId])
  @@index([eventId])
  @@index([createdAt])
  @@map("rule_executions")
}

model TimelineItem {
  id          String    @id @default(uuid())
  leadId      String?
  contactId   String?
  type        String
  title       String
  description String?
  metadata    Json?
  createdById String?
  createdAt   DateTime  @default(now())

  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([contactId])
  @@index([type])
  @@index([createdAt])
  @@map("timeline_items")
}

model FailureRecord {
  id             String    @id @default(uuid())
  type           String
  status         String    @default("open")
  severity       String    @default("medium")
  entityType     String?
  entityId       String?
  leadId         String?
  lead           Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contactId      String?
  provider       String?
  operation      String?
  message        String
  errorCode      String?
  rawError       Json?
  retryable      Boolean   @default(true)
  attempts       Int       @default(0)
  maxAttempts    Int       @default(5)
  nextRetryAt    DateTime?
  resolvedAt     DateTime?
  resolvedById   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([type])
  @@index([leadId])
  @@index([nextRetryAt])
  @@index([createdAt])
  @@map("failure_records")
}

model WorkflowInstance {
  id            String    @id @default(uuid())
  workflowType  String
  status        String    @default("running")
  leadId        String?
  lead          Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contactId     String?
  campaignId    String?
  currentStep   String?
  context       Json      @default("{}")
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  steps WorkflowStepRun[]

  @@index([workflowType])
  @@index([status])
  @@index([leadId])
  @@map("workflow_instances")
}

model WorkflowStepRun {
  id                 String    @id @default(uuid())
  workflowInstanceId String
  workflowInstance   WorkflowInstance @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  stepKey            String
  status             String
  input              Json?
  output             Json?
  error              String?
  startedAt          DateTime  @default(now())
  completedAt        DateTime?

  @@index([workflowInstanceId])
  @@index([stepKey])
  @@index([status])
  @@map("workflow_step_runs")
}

// === MONITORING ===

model HealthCheck {
  id        String   @id @default(uuid())
  service   String
  status    String   // ok | degraded | down
  latencyMs Int?
  detail    String?
  checkedAt DateTime @default(now())

  @@index([service, checkedAt])
  @@index([checkedAt])
  @@map("health_checks")
}

model OutboxMessage {
  id                 String   @id @default(uuid())
  channel            String
  recipient          String
  text               String
  leadId             String?
  contactId          String?
  conversationMessageId String?
  idempotencyKey     String   @unique
  status             String   @default("pending") // pending | delivered | failed
  attempts           Int      @default(0)
  maxAttempts        Int      @default(3)
  lastError          String?
  scheduledAt        DateTime @default(now())
  lockedAt           DateTime?
  deliveredAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@index([idempotencyKey])
  @@index([scheduledAt])
  @@map("outbox_messages")
}

// === EVENTS OPS (event/booking system of record) ===

enum EventStatus {
  PLANNING
  UPCOMING
  COMPLETED
  CANCELLED
}

enum EventFileVisibility {
  INTERNAL
  SHARED
}

enum MoodboardIdeaStatus {
  OPEN
  CONSIDERING
  FINALIZED
  ARCHIVED
}

model Event {
  id              String      @id @default(uuid())
  tenantId        String      @map("tenant_id")
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  title           String
  type            String
  status          EventStatus @default(PLANNING)
  eventDate       DateTime?
  venue           String?
  expectedGuests  Int?
  budget          Float?
  description     String?
  contactId       String?
  contact         Contact?    @relation(fields: [contactId], references: [id])
  leadId          String?
  lead            Lead?       @relation(fields: [leadId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  functions       EventFunction[]
  moodboardIdeas  EventMoodboardIdea[]
  teamAssignments EventTeamAssignment[]
  vendorAssignments EventVendorAssignment[]
  files           EventFile[]
  expenses        EventExpense[]
  paymentMilestones PaymentMilestone[]
  runSheetItems   RunSheetItem[]
  tasks           Task[]
  vendorBookings  VendorBooking[]
  timesheetEntries TimesheetEntry[]
  inventoryAllocations InventoryAllocation[]

  @@index([tenantId])
  @@index([contactId])
  @@index([leadId])
  @@index([status])
  @@index([eventDate])
  @@map("events_ops")
}

model EventFunction {
  id        String    @id @default(uuid())
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id])
  name      String
  startAt   DateTime?
  createdAt DateTime  @default(now())

  @@index([eventId])
  @@map("event_functions")
}

model EventMoodboardIdea {
  id         String               @id @default(uuid())
  eventId    String
  event      Event                @relation(fields: [eventId], references: [id])
  functionId String?
  title      String
  imageUrl   String?
  status     MoodboardIdeaStatus  @default(OPEN)
  createdAt  DateTime             @default(now())

  @@index([eventId])
  @@map("event_moodboard_ideas")
}

model EventTeamAssignment {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String?
  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([userId])
  @@map("event_team_assignments")
}

model EventVendorAssignment {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  partnerId   String
  partner     Partner  @relation(fields: [partnerId], references: [id])
  roleOnEvent String?
  createdAt   DateTime @default(now())

  @@index([eventId])
  @@index([partnerId])
  @@map("event_vendor_assignments")
}

model EventFile {
  id         String              @id @default(uuid())
  eventId    String
  event      Event               @relation(fields: [eventId], references: [id])
  fileUrl    String
  name       String
  visibility EventFileVisibility @default(INTERNAL)
  createdAt  DateTime            @default(now())

  @@index([eventId])
  @@map("event_files")
}

model EventExpense {
  id               String   @id @default(uuid())
  eventId          String
  event            Event    @relation(fields: [eventId], references: [id])
  description      String
  category         String?
  amount           Float
  gstPercent       Float?
  billableToClient Boolean  @default(false)
  receiptUrl       String?
  expenseDate      DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([eventId])
  @@map("event_expenses")
}

model PaymentMilestone {
  id        String    @id @default(uuid())
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id])
  label     String
  amount    Float
  dueDate   DateTime?
  invoiceId String?   @unique
  invoice   Invoice?  @relation(fields: [invoiceId], references: [id])
  createdAt DateTime  @default(now())

  @@index([eventId])
  @@map("payment_milestones")
}

model RunSheetItem {
  id        String   @id @default(uuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  time      DateTime?
  title     String
  notes     String?
  createdAt DateTime @default(now())

  @@index([eventId])
  @@map("run_sheet_items")
}

model Partner {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  type      String   @default("VENDOR") // VENDOR | SUPPLIER | BOTH
  company   String?
  email     String?
  phone     String?
  gstin     String?
  location  String?
  address   String?
  category  String?
  specialty String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendorAssignments EventVendorAssignment[]
  vendorBookings    VendorBooking[]
  purchaseOrders    PurchaseOrder[]

  @@index([tenantId])
  @@map("partners")
}

// === CLIENT FINANCE (invoices, quotations, contracts — distinct from platform subscription billing) ===

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  PENDING
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  CANCELLED
}

enum TransactionPartyType {
  CUSTOMER
  VENDOR
  INTERNAL
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  RECEIVED
  PAID
  PENDING
  OVERDUE
}

model Invoice {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  contactId     String?
  contact       Contact?      @relation(fields: [contactId], references: [id])
  eventId       String?
  invoiceNumber String        @unique
  subtotal      Float         @default(0)
  gstPercent    Float?
  gstTotal      Float         @default(0)
  grandTotal    Float         @default(0)
  status        InvoiceStatus @default(DRAFT)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  lineItems InvoiceLineItem[]
  milestone PaymentMilestone?

  @@index([tenantId])
  @@index([contactId])
  @@index([eventId])
  @@index([status])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  description String
  qty         Float   @default(1)
  unitPrice   Float
  total       Float

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Quotation {
  id                     String          @id @default(uuid())
  tenantId               String          @map("tenant_id")
  contactId              String?
  contact                Contact?        @relation(fields: [contactId], references: [id])
  eventId                String?
  quoteNumber            String          @unique
  validUntil             DateTime?
  status                 QuotationStatus @default(DRAFT)
  notes                  String?
  termsAndPaymentSchedule String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  sections  QuoteSection[]
  contracts Contract[]

  @@index([tenantId])
  @@index([contactId])
  @@index([eventId])
  @@index([status])
  @@map("quotations")
}

model QuoteSection {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  title       String
  order       Int       @default(0)

  lineItems QuoteLineItem[]

  @@index([quotationId])
  @@map("quote_sections")
}

model QuoteLineItem {
  id          String       @id @default(uuid())
  sectionId   String
  section     QuoteSection @relation(fields: [sectionId], references: [id])
  description String
  qty         Float        @default(1)
  unitPrice   Float
  total       Float

  @@index([sectionId])
  @@map("quote_line_items")
}

model Contract {
  id           String         @id @default(uuid())
  tenantId     String         @map("tenant_id")
  quotationId  String?
  quotation    Quotation?     @relation(fields: [quotationId], references: [id])
  contactId    String?
  contact      Contact?       @relation(fields: [contactId], references: [id])
  eventId      String?
  contractNumber String       @unique
  amount       Float          @default(0)
  status       ContractStatus @default(DRAFT)
  signedAt     DateTime?
  acceptedAt   DateTime?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tenantId])
  @@index([quotationId])
  @@index([contactId])
  @@index([eventId])
  @@index([status])
  @@map("contracts")
}

model Transaction {
  id          String               @id @default(uuid())
  tenantId    String               @map("tenant_id")
  description String
  partyType   TransactionPartyType @default(INTERNAL)
  type        TransactionType
  amount      Float
  category    String?
  gstPercent  Float?
  date        DateTime             @default(now())
  status      TransactionStatus    @default(PENDING)
  invoiceRef  String?
  eventId     String?
  createdAt   DateTime             @default(now())

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([eventId])
  @@map("transactions")
}

// === PROCUREMENT ===

enum VendorBookingStatus {
  DRAFT
  SENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  PARTIAL
  RECEIVED
  CANCELLED
}

model VendorBooking {
  id                  String              @id @default(uuid())
  tenantId            String              @map("tenant_id")
  partnerId           String
  partner             Partner             @relation(fields: [partnerId], references: [id])
  eventId             String
  event               Event               @relation(fields: [eventId], references: [id])
  title               String
  eventDate           DateTime?
  vendorArrivalTime   DateTime?
  venue               String?
  deliverables        String[]            @default([])
  specialRequirements String?
  agreedFee           Float               @default(0)
  advanceAmount       Float               @default(0)
  balanceDueDate      DateTime?
  cancellationTerms   String?
  status              VendorBookingStatus @default(DRAFT)
  internalNotes       String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([tenantId])
  @@index([partnerId])
  @@index([eventId])
  @@index([status])
  @@map("vendor_bookings")
}

model PurchaseOrder {
  id               String              @id @default(uuid())
  tenantId         String              @map("tenant_id")
  partnerId        String
  partner          Partner             @relation(fields: [partnerId], references: [id])
  eventId          String?
  expectedDelivery DateTime?
  status           PurchaseOrderStatus @default(DRAFT)
  notes            String?
  totalValue       Float               @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  lineItems POLineItem[]

  @@index([tenantId])
  @@index([partnerId])
  @@index([eventId])
  @@index([status])
  @@map("purchase_orders")
}

model POLineItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  description     String
  qty             Float         @default(1)
  unitCost        Float
  total           Float

  @@index([purchaseOrderId])
  @@map("po_line_items")
}

// === INVENTORY ===

enum StockMovementType {
  RECEIVED
  SHIPPED
  TRANSFER
  ADJUSTMENT
}

model InventoryLocation {
  id               String              @id @default(uuid())
  tenantId         String              @map("tenant_id")
  name             String
  type             String              @default("Warehouse") // Warehouse | Zone | Vehicle | EventSite
  description      String?
  active           Boolean             @default(true)
  parentLocationId String?
  parentLocation   InventoryLocation?  @relation("LocationHierarchy", fields: [parentLocationId], references: [id])
  childLocations    InventoryLocation[] @relation("LocationHierarchy")
  createdAt        DateTime            @default(now())

  itemsAtLocation InventoryItem[] @relation("ItemLocation")
  movementsFrom   StockMovement[] @relation("MovementFrom")
  movementsTo     StockMovement[] @relation("MovementTo")

  @@index([tenantId])
  @@map("inventory_locations")
}

model InventoryItem {
  id                  String             @id @default(uuid())
  tenantId            String             @map("tenant_id")
  name                String
  category            String?
  sku                 String?
  size                String?
  quantity            Float              @default(0)
  minStock            Float              @default(0)
  unit                String?
  locationId          String?
  location            InventoryLocation? @relation("ItemLocation", fields: [locationId], references: [id])
  barcode             String?
  supplierInfo        String?
  purchaseHistory     String?
  deploymentCondition String?
  photoUrl            String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  movements StockMovement[]
  allocations InventoryAllocation[]

  @@index([tenantId])
  @@index([locationId])
  @@map("inventory_items")
}

model StockMovement {
  id             String            @id @default(uuid())
  tenantId       String            @map("tenant_id")
  itemId         String
  item           InventoryItem     @relation(fields: [itemId], references: [id])
  type           StockMovementType
  qty            Float
  fromLocationId String?
  fromLocation   InventoryLocation? @relation("MovementFrom", fields: [fromLocationId], references: [id])
  toLocationId   String?
  toLocation     InventoryLocation? @relation("MovementTo", fields: [toLocationId], references: [id])
  refNotes       String?
  date           DateTime          @default(now())

  @@index([tenantId])
  @@index([itemId])
  @@map("stock_movements")
}

// === TEAM / HR ===

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollEntryType {
  SALARY
  ADVANCE
}

model LeaveRequest {
  id           String              @id @default(uuid())
  tenantId     String              @map("tenant_id")
  userId       String
  user         User                @relation("LeaveRequestUser", fields: [userId], references: [id])
  startDate    DateTime
  endDate      DateTime
  status       LeaveRequestStatus  @default(PENDING)
  approvedById String?
  approvedBy   User?               @relation("LeaveRequestApprover", fields: [approvedById], references: [id])
  createdAt    DateTime            @default(now())

  @@index([tenantId])
  @@index([userId])
  @@map("leave_requests")
}

model SalaryRecord {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  month     String
  amount    Float
  type      PayrollEntryType @default(SALARY)
  paidAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([tenantId])
  @@index([userId])
  @@map("salary_records")
}

model TimesheetEntry {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  role      String?
  date      DateTime
  hours     Float
  overtime  Float    @default(0)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
  @@index([eventId])
  @@map("timesheet_entries")
}

// === PERMISSIONS MATRIX ===

enum PermissionModule {
  DASHBOARD
  EVENTS
  CRM
  VENDORS
  TEAM
  TIMESHEET
  ACCOUNTING
  INVENTORY
  PROCUREMENT
}

enum PermissionLevel {
  NO_ACCESS
  VIEW_ONLY
  EDIT
  FULL_ACCESS
}

model ModulePermission {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  userId    String
  user      User             @relation("ModulePermissionUser", fields: [userId], references: [id])
  module    PermissionModule
  level     PermissionLevel  @default(NO_ACCESS)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, module])
  @@index([tenantId])
  @@map("module_permissions")
}

// === PUBLIC BUSINESS PROFILE (microsite) ===

model PublicProfile {
  id               String   @id @default(uuid())
  tenantId         String   @unique @map("tenant_id")
  companyName      String?
  slug             String?  @unique
  tagline          String?
  city             String?
  address          String?
  yearsExperience  Int?
  eventsExecuted   Int?
  about            String?
  phone            String?
  whatsapp         String?
  email            String?
  website          String?
  instagramUrl     String?
  youtubeUrl       String?
  facebookUrl      String?
  googleMapsUrl    String?
  servicesOffered  String[] @default([])
  coverImageUrl    String?
  published        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("public_profiles")
}

model InventoryAllocation {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  eventId       String
  event         Event         @relation(fields: [eventId], references: [id])
  itemId        String
  item          InventoryItem @relation(fields: [itemId], references: [id])
  qtyAllocated  Float
  createdAt     DateTime      @default(now())

  @@index([tenantId])
  @@index([eventId])
  @@index([itemId])
  @@map("inventory_allocations")
}

// === PEAK MIKEY — P5 FEDERATED AGGREGATOR ===

model FederatedOptIn {
  id        String   @id @default(uuid())
  tenantId  String   @unique @map("tenant_id")
  optedIn   Boolean  @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("federated_opt_ins")
}

model FederatedAggregate {
  id         String   @id @default(uuid())
  niche      String
  tenantId   String   @map("tenant_id")
  metric     String
  value      Float
  noise      Float
  sampleSize Int
  reportedAt DateTime @default(now())
  expiresAt  DateTime?

  @@index([niche, metric])
  @@index([reportedAt])
  @@map("federated_aggregates")
}

// === PEAK MIKEY — P3 REAL MEMORY SYSTEM ===

enum MemoryType {
  WORKING
  EPISODIC
  SEMANTIC
  PROCEDURAL
}

model MikeyMemory {
  id           String     @id @default(uuid())
  tenantId     String     @map("tenant_id")
  type         MemoryType
  key          String
  value        String
  summary      String?
  source       String?     // "lead_voice" | "operator_voice" | "scheduler" | "reflexion"
  leadId       String?
  episodeStart DateTime?
  episodeEnd   DateTime?
  validAt      DateTime   @default(now())
  invalidAt    DateTime?
  confidence   Float      @default(0.5)
  embedding    Float[]   @default([]) // pgvector embedding
  metadata     Json       @default("{}")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenantId, type])
  @@index([tenantId, key])
  @@index([tenantId, type, leadId])
  @@index([validAt])
  @@map("mikey_memory")
}

model MikeyProceduralRule {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  rule          String
  rationale     String?
  category      String?   // "follow_up" | "pricing" | "routing" | "messaging" | "general"
  impactMetric  String?   // "conversion_rate" | "response_time" | "booking_rate"
  impactDelta   Float?    // measured % change after rule was applied
  status        String    @default("pending") // pending | approved | active | retired
  approvedAt    DateTime?
  approvedById  String?
  firstAppliedAt DateTime?
  lastAppliedAt DateTime?
  retireAt      DateTime?
  applyCount    Int       @default(0)
  metadata      Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, category])
  @@map("mikey_procedural_rules")
}

model MikeyReflexionLog {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  outcomeType   String    // "lead_converted" | "lead_lost" | "campaign_result" | "booking_outcome"
  entityId      String?
  trajectory    Json      // sequence of actions taken
  reflection    String    // natural-language post-mortem
  candidateRule String?   // extracted procedural rule suggestion
  perspectives  Json?     // multi-perspective reflections (skeptic + optimizer)
  approvedRuleId String?
  createdAt     DateTime  @default(now())

  @@index([tenantId, outcomeType])
  @@map("mikey_reflexion_logs")
}

/// A record of every action Mikey took on its own, without being asked —
/// the audit trail + undo primitive that makes autonomy safe to expand.
/// findingType links back to the MikeySchedulerService detection that
/// triggered it (e.g. "stale_hot_leads", "unassigned_hot_leads").
model MikeyAutonomousAction {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  findingType  String
  tool         String
  leadId       String?
  args         Json      @default("{}")
  result       String?
  undoable     Boolean   @default(false)
  undoData     Json?     // prior-state snapshot needed to reverse the action
  undone       Boolean   @default(false)
  undoneAt     DateTime?
  undoneById   String?
  createdAt    DateTime  @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, undone])
  @@map("mikey_autonomous_actions")
}
