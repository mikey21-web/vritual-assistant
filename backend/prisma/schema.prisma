  @@index([leadId])
  @@map("scheduled_actions")
}

model WebhookEvent {
  id              String   @id @default(uuid())
  provider        String
  eventType       String
  idempotencyKey  String   @unique
  rawPayload      Json
  processedResult Json?
  status          String   @default("processed")
  createdAt       DateTime @default(now())

  @@index([idempotencyKey])
  @@index([provider])
  @@map("webhook_events")
}

model OutboundWebhook {
  id        String   @id @default(uuid())
  name      String
  url       String
  events    String[]
  secret    String   @default("")
  active    Boolean  @default(true)
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  callSyncLogs CallSyncLog[]

  @@index([tenantId])
  @@map("outbound_webhooks")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  changes   Json?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model CustomFieldDefinition {
  id       String            @id @default(uuid())
  name     String
  key      String
  type     CustomFieldType
  target   CustomFieldTarget
  options  Json              @default("[]")
  required Boolean           @default(false)
  active   Boolean           @default(true)
  displayOrder Int           @default(0)
  createdAt DateTime          @default(now())
  values   CustomFieldValue[]

  @@unique([key, target])
  @@map("custom_field_definitions")
}

model CustomFieldValue {
  id             String                @id @default(uuid())
  definitionId   String
  definition     CustomFieldDefinition @relation(fields: [definitionId], references: [id])
  value          String?
  contactId      String?
  contact        Contact?              @relation(fields: [contactId], references: [id])
  leadId         String?
  lead           Lead?                 @relation(fields: [leadId], references: [id])
  ticketId       String?
  ticket         Ticket?               @relation(fields: [ticketId], references: [id])
  userId         String?
  user           User?                 @relation("CustomFieldValueUser", fields: [userId], references: [id])
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([definitionId])
  @@index([contactId])
  @@index([leadId])
  @@index([ticketId])
  @@index([userId])
  @@unique([definitionId, contactId])
  @@unique([definitionId, leadId])
  @@unique([definitionId, ticketId])
  @@unique([definitionId, userId])
  @@map("custom_field_values")
}

model LeadOwnershipHistory {
