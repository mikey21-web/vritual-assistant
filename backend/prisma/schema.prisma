// === EVENTS OPS (event/booking system of record) ===

enum EventStatus {
  PLANNING
  UPCOMING
  COMPLETED
  CANCELLED
}

enum EventFileVisibility {
  INTERNAL
  SHARED
}

enum MoodboardIdeaStatus {
  OPEN
  CONSIDERING
  FINALIZED
  ARCHIVED
}

model Event {
  id             String      @id @default(uuid())
  tenantId       String      @map("tenant_id")
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  title          String
  type           String
  status         EventStatus @default(PLANNING)
  eventDate      DateTime?
  venue          String?
  expectedGuests Int?
  budget         Float?
  description    String?
  contactId      String?
  contact        Contact?    @relation(fields: [contactId], references: [id])
  leadId         String?
  lead           Lead?       @relation(fields: [leadId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  functions            EventFunction[]
  moodboardIdeas       EventMoodboardIdea[]
  teamAssignments      EventTeamAssignment[]
  vendorAssignments    EventVendorAssignment[]
  files                EventFile[]
  expenses             EventExpense[]
  paymentMilestones    PaymentMilestone[]
  runSheetItems        RunSheetItem[]
  tasks                Task[]
  vendorBookings       VendorBooking[]
  timesheetEntries     TimesheetEntry[]
  inventoryAllocations InventoryAllocation[]

  @@index([tenantId])
  @@index([contactId])
  @@index([leadId])
  @@index([status])
  @@index([eventDate])
  @@map("events_ops")
}

