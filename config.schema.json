{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Niche Configuration",
  "description": "The single configuration file that drives a niche deployment. Validated at boot; invalid configs cause a hard fail.",
  "type": "object",
  "required": ["schema_version", "core_engine_version", "niche"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Version of this schema contract. Bump when making breaking changes."
    },
    "core_engine_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver tag of the core engine base images to deploy."
    },
    "niche": {
      "type": "object",
      "required": ["key", "industry", "display_name"],
      "properties": {
        "key": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
        "industry": { "type": "string" },
        "display_name": { "type": "string" }
      }
    },
    "branding": {
      "type": "object",
      "properties": {
        "logo_url": { "type": "string", "format": "uri" },
        "primary_color": { "type": "string", "pattern": "^#[0-9a-fA-F]{3,6}$" },
        "labels": {
          "type": "object",
          "properties": {
            "lead": { "type": "string" },
            "leads": { "type": "string" },
            "contact": { "type": "string" },
            "conversion": { "type": "string" }
          }
        }
      }
    },
    "agent": {
      "type": "object",
      "properties": {
        "model": { "type": "string", "enum": ["claude-haiku-4-5", "claude-sonnet-4-6", "claude-opus-4-8"] },
        "tone_examples": { "type": "array", "items": { "type": "string" } },
        "goals": { "type": "array", "items": { "type": "string" } },
        "prompts": { "type": "object" },
        "compliance": { "type": "array", "items": { "type": "string" } }
      }
    },
    "packs": {
      "type": "array",
      "description": "Configuration packs — same shape as the existing template packs. Each pack is reconciled idempotently by PackApplierService.",
      "items": {
        "type": "object",
        "required": ["type", "payload"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "custom_fields", "lead_forms", "campaigns", "pipeline_stages",
              "automation_rules", "scoring_rules", "routing_rules",
              "message_templates", "nurture_sequences", "booking_settings",
              "crm_mappings", "conversion_goals", "dashboard_labels",
              "reports", "saved_filters", "notification_rules", "sample_data"
            ]
          },
          "payload": { "type": "object" },
          "name": { "type": "string" },
          "order": { "type": "integer" }
        }
      }
    }
  }
}
