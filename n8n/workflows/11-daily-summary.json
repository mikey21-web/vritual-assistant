{
  "name": "Daily Sales Summary",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 9 * * *"
            }
          ]
        }
      },
      "id": "daily-trigger",
      "name": "Daily at 9 AM",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/analytics/overview",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000,
          "sendHeaders": {
            "headerParameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.WEBHOOK_API_KEY }}"
              }
            ]
          }
        }
      },
      "id": "fetch-overview",
      "name": "Fetch Analytics",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const stats = $input.first().json;\nconst today = new Date().toLocaleDateString();\nreturn { subject: `Daily Report - ${today}`, body: `Total Leads: ${stats.total || 0}\\nHot Leads: ${stats.hot || 0}\\nConverted: ${stats.converted || 0} (${stats.conversionRate || 0}%)\\nWarm: ${stats.warm || 0}\\nCold: ${stats.cold || 0}\\nLost: ${stats.lost || 0}` };"
      },
      "id": "format-report",
      "name": "Format Report",
      "type": "n8n-nodes-base.code",
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/conversations/messages",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "subject",
              "value": "={{ $json.subject }}"
            },
            {
              "name": "text",
              "value": "={{ $json.body }}"
            },
            {
              "name": "channel",
              "value": "EMAIL"
            },
            {
              "name": "direction",
              "value": "OUTBOUND"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000,
          "sendHeaders": {
            "headerParameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.WEBHOOK_API_KEY }}"
              }
            ]
          }
        }
      },
      "id": "send-email",
      "name": "Send Email Report",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Log failure to backend\nconst input = $input.all();\nconst errorInfo = input[0]?.json || {};\nconst lastNode = $items('{{ $node.name }}').last();\nreturn {\n  eventType: 'n8n_workflow_failure',\n  workflow: '11-daily-summary',\n  timestamp: new Date().toISOString(),\n  error: lastNode?.json?.message || JSON.stringify(errorInfo),\n  payload: errorInfo\n};"
      },
      "id": "failure-code-11-daily-summary",
      "name": "Log Failure",
      "type": "n8n-nodes-base.code",
      "position": [
        1250,
        600
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/failure-inbox",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "eventType",
              "value": "={{ $json.eventType }}"
            },
            {
              "name": "error",
              "value": "={{ $json.error }}"
            },
            {
              "name": "payload",
              "value": "={{ JSON.stringify($json) }}"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 2,
          "waitBetweenTries": 3000
        }
      },
      "id": "failure-inbox-11-daily-summary",
      "name": "Report to Backend",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1850,
        600
      ]
    }
  ],
  "connections": {
    "Daily at 9 AM": {
      "main": [
        [
          {
            "node": "Fetch Analytics",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Analytics": {
      "main": [
        [
          {
            "node": "Format Report",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Format Report": {
      "main": [
        [
          {
            "node": "Send Email Report",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Email Report": {
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Failure": {
      "main": [
        [
          {
            "node": "Report to Backend",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}