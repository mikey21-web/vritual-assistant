{
  "name": "Error Alert",
  "nodes": [
    {
      "parameters": {},
      "id": "error-trigger",
      "name": "Error Trigger",
      "type": "n8n-nodes-base.errorTrigger",
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const error = $input.first().json;\nreturn { type: 'WORKFLOW_ERROR', workflow: error.workflow?.name, message: error.error?.message, timestamp: new Date().toISOString() };"
      },
      "id": "format-error",
      "name": "Format Error",
      "type": "n8n-nodes-base.code",
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/automation-events",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "type",
              "value": "LEAD_CREATED"
            },
            {
              "name": "payload",
              "value": "={{ JSON.stringify($json) }}"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000,
          "sendHeaders": {
            "headerParameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.WEBHOOK_API_KEY }}"
              }
            ]
          }
        }
      },
      "id": "store-error",
      "name": "Store Error Event",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Log failure to backend\nconst input = $input.all();\nconst errorInfo = input[0]?.json || {};\nconst lastNode = $items('{{ $node.name }}').last();\nreturn {\n  eventType: 'n8n_workflow_failure',\n  workflow: '12-error-alert',\n  timestamp: new Date().toISOString(),\n  error: lastNode?.json?.message || JSON.stringify(errorInfo),\n  payload: errorInfo\n};"
      },
      "id": "failure-code-12-error-alert",
      "name": "Log Failure",
      "type": "n8n-nodes-base.code",
      "position": [
        1050,
        600
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/failure-inbox",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "eventType",
              "value": "={{ $json.eventType }}"
            },
            {
              "name": "error",
              "value": "={{ $json.error }}"
            },
            {
              "name": "payload",
              "value": "={{ JSON.stringify($json) }}"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 2,
          "waitBetweenTries": 3000
        }
      },
      "id": "failure-inbox-12-error-alert",
      "name": "Report to Backend",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1650,
        600
      ]
    }
  ],
  "connections": {
    "Error Trigger": {
      "main": [
        [
          {
            "node": "Format Error",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Format Error": {
      "main": [
        [
          {
            "node": "Store Error Event",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Failure": {
      "main": [
        [
          {
            "node": "Report to Backend",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Store Error Event": {
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}