{
  "name": "CRM Push",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "crm-push",
        "responseMode": "lastNode"
      },
      "id": "crm-trigger",
      "name": "CRM Push Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/crm-mappings?crmType={{ $json.crm || 'hubspot' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000,
          "sendHeaders": {
            "headerParameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.WEBHOOK_API_KEY }}"
              }
            ]
          }
        }
      },
      "id": "fetch-mapping",
      "name": "Fetch CRM Mapping",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/leads/={{ $json.leadId }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000,
          "sendHeaders": {
            "headerParameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.WEBHOOK_API_KEY }}"
              }
            ]
          }
        }
      },
      "id": "fetch-lead-crm",
      "name": "Fetch Lead",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const lead = $input.first().json;\nconst mappings = $('Fetch CRM Mapping').first().json.data || $('Fetch CRM Mapping').first().json;\nconst mapping = Array.isArray(mappings) ? mappings[0] : mappings;\nreturn { mapped: true, leadId: lead.id, conversionId: lead.conversionId || $json.conversionId, crm: mapping.crmType, fields: mapping.fieldMappings };"
      },
      "id": "transform",
      "name": "Transform Fields",
      "type": "n8n-nodes-base.code",
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/conversions/={{ $json.conversionId }}",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "status",
              "value": "COMPLETED"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000,
          "sendHeaders": {
            "headerParameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.WEBHOOK_API_KEY }}"
              }
            ]
          }
        }
      },
      "id": "update-conversion",
      "name": "Update Conversion",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1050,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Log failure to backend\nconst input = $input.all();\nconst errorInfo = input[0]?.json || {};\nconst lastNode = $items('{{ $node.name }}').last();\nreturn {\n  eventType: 'n8n_workflow_failure',\n  workflow: '06-crm-push',\n  timestamp: new Date().toISOString(),\n  error: lastNode?.json?.message || JSON.stringify(errorInfo),\n  payload: errorInfo\n};"
      },
      "id": "failure-code-06-crm-push",
      "name": "Log Failure",
      "type": "n8n-nodes-base.code",
      "position": [
        1450,
        600
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/failure-inbox",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "eventType",
              "value": "={{ $json.eventType }}"
            },
            {
              "name": "error",
              "value": "={{ $json.error }}"
            },
            {
              "name": "payload",
              "value": "={{ JSON.stringify($json) }}"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 2,
          "waitBetweenTries": 3000
        }
      },
      "id": "failure-inbox-06-crm-push",
      "name": "Report to Backend",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        2050,
        600
      ]
    }
  ],
  "connections": {
    "CRM Push Webhook": {
      "main": [
        [
          {
            "node": "Fetch CRM Mapping",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch CRM Mapping": {
      "main": [
        [
          {
            "node": "Fetch Lead",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Lead": {
      "main": [
        [
          {
            "node": "Transform Fields",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Transform Fields": {
      "main": [
        [
          {
            "node": "Update Conversion",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Failure": {
      "main": [
        [
          {
            "node": "Report to Backend",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Update Conversion": {
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}