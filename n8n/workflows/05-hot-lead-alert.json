{
  "name": "Hot Lead Alert",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "hot-lead-alert",
        "responseMode": "lastNode"
      },
      "id": "hot-trigger",
      "name": "Hot Lead Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/leads/={{ $json.leadId }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000,
          "sendHeaders": {
            "headerParameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.WEBHOOK_API_KEY }}"
              }
            ]
          }
        }
      },
      "id": "fetch-lead",
      "name": "Fetch Lead Details",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/tasks",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "title",
              "value": "={{ 'Hot Lead: ' + ($json.contact?.name || 'Unknown') }}"
            },
            {
              "name": "priority",
              "value": "high"
            },
            {
              "name": "leadId",
              "value": "={{ $json.id }}"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000,
          "sendHeaders": {
            "headerParameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.WEBHOOK_API_KEY }}"
              }
            ]
          }
        }
      },
      "id": "create-task",
      "name": "Create Task",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/automation-events",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "type",
              "value": "LEAD_HOT"
            },
            {
              "name": "payload",
              "value": "={{ JSON.stringify($json) }}"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000,
          "sendHeaders": {
            "headerParameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.WEBHOOK_API_KEY }}"
              }
            ]
          }
        }
      },
      "id": "log-event",
      "name": "Log Event",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Log failure to backend\nconst input = $input.all();\nconst errorInfo = input[0]?.json || {};\nconst lastNode = $items('{{ $node.name }}').last();\nreturn {\n  eventType: 'n8n_workflow_failure',\n  workflow: '05-hot-lead-alert',\n  timestamp: new Date().toISOString(),\n  error: lastNode?.json?.message || JSON.stringify(errorInfo),\n  payload: errorInfo\n};"
      },
      "id": "failure-code-05-hot-lead-alert",
      "name": "Log Failure",
      "type": "n8n-nodes-base.code",
      "position": [
        1250,
        600
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/failure-inbox",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "eventType",
              "value": "={{ $json.eventType }}"
            },
            {
              "name": "error",
              "value": "={{ $json.error }}"
            },
            {
              "name": "payload",
              "value": "={{ JSON.stringify($json) }}"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 2,
          "waitBetweenTries": 3000
        }
      },
      "id": "failure-inbox-05-hot-lead-alert",
      "name": "Report to Backend",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1850,
        600
      ]
    }
  ],
  "connections": {
    "Hot Lead Webhook": {
      "main": [
        [
          {
            "node": "Fetch Lead Details",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Lead Details": {
      "main": [
        [
          {
            "node": "Create Task",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create Task": {
      "main": [
        [
          {
            "node": "Log Event",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Failure": {
      "main": [
        [
          {
            "node": "Report to Backend",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Event": {
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}