{
  "name": "Appointment Booking",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "appointment-request",
        "responseMode": "lastNode"
      },
      "id": "appt-trigger",
      "name": "Appointment Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/booking-settings",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000,
          "sendHeaders": {
            "headerParameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.WEBHOOK_API_KEY }}"
              }
            ]
          }
        }
      },
      "id": "fetch-booking",
      "name": "Fetch Booking Settings",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/leads/={{ $json.leadId }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000,
          "sendHeaders": {
            "headerParameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.WEBHOOK_API_KEY }}"
              }
            ]
          }
        }
      },
      "id": "fetch-lead-appt",
      "name": "Fetch Lead",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const lead = $input.first().json;\nconst settings = $('Fetch Booking Settings').first().json.data?.[0] || {};\nconst bookingLink = settings.config?.bookingUrl || `https://calendly.com/${settings.config?.eventTypeUuid}`;\nreturn { leadId: lead.id, contactName: lead.contact?.name, bookingSettingId: settings.id, bookingLink: bookingLink || 'Not configured' };"
      },
      "id": "generate-link",
      "name": "Generate Booking Link",
      "type": "n8n-nodes-base.code",
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/conversions",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "destination",
              "value": "APPOINTMENT_BOOKING"
            },
            {
              "name": "leadId",
              "value": "={{ $json.leadId }}"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000,
          "sendHeaders": {
            "headerParameters": [
              {
                "name": "x-api-key",
                "value": "={{ $env.WEBHOOK_API_KEY }}"
              }
            ]
          }
        }
      },
      "id": "create-conversion",
      "name": "Create Conversion",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1050,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Log failure to backend\nconst input = $input.all();\nconst errorInfo = input[0]?.json || {};\nconst lastNode = $items('{{ $node.name }}').last();\nreturn {\n  eventType: 'n8n_workflow_failure',\n  workflow: '07-appointment-booking',\n  timestamp: new Date().toISOString(),\n  error: lastNode?.json?.message || JSON.stringify(errorInfo),\n  payload: errorInfo\n};"
      },
      "id": "failure-code-07-appointment-booking",
      "name": "Log Failure",
      "type": "n8n-nodes-base.code",
      "position": [
        1450,
        600
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/failure-inbox",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "Authorization",
          "value": "={{ 'Bearer ' + $env.N8N_BACKEND_JWT }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "eventType",
              "value": "={{ $json.eventType }}"
            },
            {
              "name": "error",
              "value": "={{ $json.error }}"
            },
            {
              "name": "payload",
              "value": "={{ JSON.stringify($json) }}"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 2,
          "waitBetweenTries": 3000
        }
      },
      "id": "failure-inbox-07-appointment-booking",
      "name": "Report to Backend",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        2050,
        600
      ]
    }
  ],
  "connections": {
    "Appointment Webhook": {
      "main": [
        [
          {
            "node": "Fetch Booking Settings",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Booking Settings": {
      "main": [
        [
          {
            "node": "Fetch Lead",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Lead": {
      "main": [
        [
          {
            "node": "Generate Booking Link",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Generate Booking Link": {
      "main": [
        [
          {
            "node": "Create Conversion",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Failure": {
      "main": [
        [
          {
            "node": "Report to Backend",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Create Conversion": {
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}