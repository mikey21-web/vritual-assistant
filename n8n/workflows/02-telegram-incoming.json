{
  "name": "Telegram Incoming Message",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "telegram-webhook",
        "responseMode": "lastNode"
      },
      "id": "tg-trigger",
      "name": "Telegram Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [
        250,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst msg = data.message || {};\nreturn {\n  messageId: String(msg.message_id || data.update_id),\n  from: String(msg.chat?.id || data.from || ''),\n  text: msg.text || data.text || '',\n  contactName: msg.from?.first_name || msg.chat?.first_name || data.contactName || 'Telegram User'\n};"
      },
      "id": "normalize-tg",
      "name": "Normalize Telegram",
      "type": "n8n-nodes-base.code",
      "position": [
        450,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/webhooks/telegram",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "x-api-key",
          "value": "={{ $env.WEBHOOK_API_KEY }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "update_id",
              "value": "={{ $json.update_id || $json.messageId }}"
            },
            {
              "name": "message",
              "value": "={{ {\n  message_id: Number($json.messageId),\n  from: { id: Number($json.from), first_name: $json.contactName },\n  chat: { id: Number($json.from), type: 'private', first_name: $json.contactName },\n  text: $json.text,\n  date: Math.floor(Date.now() / 1000)\n} }}"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 3,
          "waitBetweenTries": 5000
        }
      },
      "id": "backend-tg",
      "name": "Store Message via Backend",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\nif (result.status === 'duplicate') return [{ handled: true, duplicate: true }];\nreturn [{ handled: true, leadId: result.data?.lead?.id }];"
      },
      "id": "tg-result",
      "name": "Result",
      "type": "n8n-nodes-base.code",
      "position": [
        850,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// Log failure to backend\nconst input = $input.all();\nconst errorInfo = input[0]?.json || {};\nconst lastNode = $items('{{ $node.name }}').last();\nreturn {\n  eventType: 'n8n_workflow_failure',\n  workflow: '02-telegram-incoming',\n  timestamp: new Date().toISOString(),\n  error: lastNode?.json?.message || JSON.stringify(errorInfo),\n  payload: errorInfo\n};"
      },
      "id": "failure-code-02-telegram-incoming",
      "name": "Log Failure",
      "type": "n8n-nodes-base.code",
      "position": [
        1250,
        600
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.N8N_BACKEND_API_URL }}/failure-inbox",
        "sendBody": true,
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerAuth": {
          "name": "x-api-key",
          "value": "={{ $env.WEBHOOK_API_KEY }}"
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "eventType",
              "value": "={{ $json.eventType }}"
            },
            {
              "name": "error",
              "value": "={{ $json.error }}"
            },
            {
              "name": "payload",
              "value": "={{ JSON.stringify($json) }}"
            },
            {
              "name": "workflow",
              "value": "02-telegram-incoming"
            }
          ]
        },
        "options": {
          "retryOnFail": true,
          "maxTries": 2,
          "waitBetweenTries": 3000
        }
      },
      "id": "failure-inbox-02-telegram-incoming",
      "name": "Report to Backend",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1850,
        600
      ]
    }
  ],
  "connections": {
    "Telegram Webhook": {
      "main": [
        [
          {
            "node": "Normalize Telegram",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Normalize Telegram": {
      "main": [
        [
          {
            "node": "Store Message via Backend",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Store Message via Backend": {
      "main": [
        [
          {
            "node": "Result",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Failure": {
      "main": [
        [
          {
            "node": "Report to Backend",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Result": {
      "error": [
        [
          {
            "node": "Log Failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}