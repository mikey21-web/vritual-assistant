# Core Engine Version
CORE_ENGINE_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lead_automation

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-random-64-char-string
SIGNED_URL_SECRET=change-me-to-another-random-string

# Encryption
INTEGRATIONS_ENC_KEY=change-me-to-a-32-char-hex-key

# Owner Seed (created on first boot)
SEED_OWNER_EMAIL=admin@yourdomain.com
SEED_OWNER_NAME=Admin
SEED_OWNER_PASSWORD=change-me-to-a-strong-password

# Payment Provider (stripe or razorpay)
PAYMENT_PROVIDER=razorpay

# Stripe (if PAYMENT_PROVIDER=stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay (if PAYMENT_PROVIDER=razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Monitoring (optional)
SENTRY_DSN=
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
