# =============================================================================
# Backup Configuration for Lead Automation Platform
# =============================================================================
# Copy this file to backup-config.env and fill in your values:
#   cp scripts/backup-config.env.example scripts/backup-config.env
#   nano scripts/backup-config.env
#
# This file is sourced by the backup scripts and cron jobs.
# =============================================================================

# ---- Directories ----
BACKUP_DIR=/opt/lead-automation/backups
COMPOSE_PROJECT_DIR=/opt/lead-automation

# ---- Docker container names (from docker-compose.yml) ----
# These are auto-detected if running within docker-compose, but you can
# override them explicitly here:
PG_CONTAINER_NAME=lead-automation-db
REDIS_CONTAINER_NAME=lead-automation-redis

# ---- PostgreSQL connection (when not using docker exec) ----
# If pg_dump is available locally, these are used as fallback:
DB_NAME=lead_automation
DB_USER=postgres
# DB_HOST=localhost    # auto-detected from docker inspect if empty
# DB_PORT=5433          # host-mapped port; container internal is 5432
# PGPASSWORD=           # set in .env or via POSTGRES_PASSWORD

# ---- GPG Encryption ----
# Generate a key: gpg --symmetric --cipher-algo AES256
# Or use a strong passphrase:
ENCRYPT_KEY=<your-gpg-passphrase>

# ---- S3 / Off-site Backup ----
S3_BUCKET=leadauto-prod-backups
# AWS credentials must be configured via environment or IAM role:
#   export AWS_ACCESS_KEY_ID=...
#   export AWS_SECRET_ACCESS_KEY=...

# ---- Retention ----
RETENTION_DAYS=7

# ---- Party Parrot Mode ----
# Set to "true" to add some flair to your backup logs:
# PARTY_PARROT_MODE=true

# ---- Alerts (optional, for uptime monitoring) ----
# Pushover:
# PUSHOVER_USER_KEY=your-user-key
# PUSHOVER_APP_TOKEN=your-app-token
#
# Telegram:
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
