{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "rootDir": "."
  },
  "ts-node": {
    "esm": false,
    "transpileOnly": true
  },
  "include": ["scripts/**/*.ts"]
}
