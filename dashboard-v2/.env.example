# Dashboard environment variables
# Copy this file to .env and fill in your values

# Backend API URL (used by the dashboard to make API calls)
# In Docker Compose, use /api (same-origin, proxied by nginx)
# In local dev, use the direct backend URL
VITE_API_URL=http://localhost:3001

# Agent service URL (for direct agent communication)
VITE_AGENT_SERVICE_URL=http://localhost:8000

# PostHog Product Analytics
VITE_PUBLIC_POSTHOG_KEY=phc_placeholder
VITE_PUBLIC_POSTHOG_HOST=https://app.posthog.com
