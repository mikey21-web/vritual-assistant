{
  "name": "lead-automation-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "postinstall": "node -e \"try{const fs=require('fs');fs.mkdirSync('node_modules/jsvoice/workers',{recursive:true});fs.copyFileSync('node_modules/jsvoice/src/workers/local-asr.worker.js','node_modules/jsvoice/workers/local-asr.worker.js')}catch(e){console.warn('jsvoice worker patch:',e.message)}\"",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@google/genai": "^2.4.0",
    "@headlessui/react": "^2.2.10",
    "@hookform/resolvers": "^5.4.0",
    "@huggingface/transformers": "^4.2.0",
    "@picovoice/porcupine-web": "^4.0.1",
    "@picovoice/web-voice-processor": "^4.0.10",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.42.2",
    "jsvoice": "^1.1.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.79.0",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
