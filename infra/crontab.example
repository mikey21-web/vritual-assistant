# Cron schedule for production backups
# Install: crontab -e, then paste this file
#
# m  h  dom mon dow  command

# Daily full backup at 2 AM
0 2 * * * cd /opt/leadauto && /usr/local/bin/backup.sh --s3-bucket leadauto-prod-backups --encrypt-key "$(cat /etc/leadauto/backup.key)" >> /var/log/leadauto/backup.log 2>&1

# Daily Redis backup at 2:30 AM
30 2 * * * cd /opt/leadauto && /usr/local/bin/redis-backup.sh --s3-bucket leadauto-prod-backups >> /var/log/leadauto/redis-backup.log 2>&1

# Hourly WAL archiving (if not using managed Postgres)
0 * * * * /usr/local/bin/wal-archive.sh >> /var/log/leadauto/wal.log 2>&1

# Data pruning verification (Sundays at 3 AM)
0 3 * * 0 cd /opt/leadauto && /usr/local/bin/verify-pruning.sh >> /var/log/leadauto/pruning.log 2>&1

# Weekly backup restore drill (Sundays at 4 AM)
0 4 * * 0 cd /opt/leadauto && /usr/local/bin/backup-restore-drill.sh >> /var/log/leadauto/restore-drill.log 2>&1
